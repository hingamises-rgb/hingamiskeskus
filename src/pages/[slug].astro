---
import Layout from '../layouts/Layout.astro';
import { readdir, readFile } from 'node:fs/promises';
import { join } from 'node:path';

export async function getStaticPaths() {
  const dir = join(process.cwd(), 'src', 'content', 'blogi');
  const files = await readdir(dir);
  const paths = [];
  for (const file of files) {
    if (!file.endsWith('.json')) continue;
    const article = JSON.parse(await readFile(join(dir, file), 'utf8'));
    paths.push({
      params: { slug: article.slug },
      props: { article },
    });
  }
  return paths;
}

const { article } = Astro.props;
const publishedDate = article.publishedTime
  ? new Date(article.publishedTime).toLocaleDateString('et-EE', { year: 'numeric', month: 'long', day: 'numeric' })
  : '';
---

<Layout title={`${article.title} | Hingamiskeskus`} description={article.description || article.title}>

<header class="header">
  <a href="/" class="header__logo">
    <img src="/images/logo.svg" alt="Hingamiskeskus" height="30" />
  </a>
  <nav class="header__nav">
    <a href="/">Avaleht</a>
    <a href="/teenused">Teenused</a>
    <a href="/broneeri-aeg">Broneeri aeg</a>
    <a href="/e-pood">E-pood</a>
    <a href="/hakka-liikmeks">Hakka liikmeks</a>
    <a href="/paketid">Paketid</a>
    <a href="/blogi" class="active">Blogi</a>
    <a href="/kkk">KKK</a>
  </nav>
  <div class="header__right">
    <a href="/e-pood" class="header__cart" aria-label="Ostukorv">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/>
      </svg>
    </a>
    <button class="header__burger" aria-label="Menüü">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<article class="article">
  <div class="article__hero">
    <h1 class="article__title">{article.title}</h1>
    {article.description && <p class="article__lead">{article.description}</p>}
    {article.categories && article.categories.length > 0 && (
      <p class="article__categories">
        {article.categories.map(c => <span class="article__category">{c}</span>)}
      </p>
    )}
    {publishedDate && <p class="article__meta">{publishedDate} · Hingamiskeskus</p>}
  </div>

  {article.image && (
    <img src={article.image} alt={article.imageAlt || article.title} class="article__image" />
  )}

  <div class="article__body" set:html={article.body}></div>

  <div class="article__cta">
    <a href="/blogi" class="article__cta-link">← Tagasi blogisse</a>
  </div>
</article>

<footer class="footer">
  <div class="location">
    <h3 class="location__title">Aadress</h3>
    <p class="location__address">Söle 14c, Tallinn</p>
    <img src="/images/hoone.jpg" alt="Hingamiskeskus Söle 14c" class="location__photo" loading="lazy" />
  </div>
  <div class="footer__main">
    <img src="/images/logo-valge.png" alt="Hingamiskeskus" class="footer__logo" />
    <div class="footer__contact">
      <h3>Kontakt</h3>
      <p>E-post: Info@hingamiskeskus.ee</p>
      <p>Telefoninumber:</p>
      <p>+372 56695898</p>
      <p>+372 56497689</p>
      <p>(klienditugi 10.00-17.00)</p>
      <p>Hingamises OÜ</p>
      <p>EE147700771009732310</p>
    </div>
    <div class="footer__hours">
      <h3>Lahtiolekuajad</h3>
      <p>E-R 8.30 - 20.00</p>
      <p>L-P 11.00 - 18.00</p>
    </div>
    <div class="footer__social">
      <a href="https://www.facebook.com/Hingamiskeskus" aria-label="Facebook" target="_blank" rel="noopener">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
      </a>
      <a href="https://www.instagram.com/hingamiskeskus/" aria-label="Instagram" target="_blank" rel="noopener">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="5"/><circle cx="17.5" cy="6.5" r="1.5" fill="currentColor" stroke="none"/></svg>
      </a>
    </div>
    <div class="footer__legal">
      <a href="/privaatsuspoliitika">Privaatsuspoliitika</a> | <a href="/muugitingimused">Müügitingimused</a>
    </div>
  </div>
</footer>

</Layout>

<style>
  .header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 10px 16px; background: #fff; position: sticky; top: 0; z-index: 100;
    border-bottom: 1px solid rgba(0,0,0,0.05);
  }
  .header__logo img { height: 28px; width: auto; }
  .header__nav { display: none; gap: 24px; }
  .header__nav a { font-size: 14px; color: #1d1e20; text-decoration: none; font-weight: 500; }
  .header__nav a.active { text-decoration: underline; text-underline-offset: 4px; }
  .header__right { display: flex; align-items: center; gap: 16px; }
  .header__cart { color: #1d1e20; }
  .header__burger { display: flex; flex-direction: column; gap: 5px; padding: 4px; background: none; border: none; cursor: pointer; }
  .header__burger span { display: block; width: 22px; height: 2px; background: #1d1e20; }
  @media (min-width: 768px) {
    .header__nav { display: flex; }
    .header__burger { display: none; }
  }

  .article {
    max-width: 780px;
    margin: 0 auto;
    padding: 40px 24px 60px;
  }

  .article__hero {
    text-align: center;
    margin-bottom: 32px;
  }

  .article__title {
    font-family: 'Libre Caslon Display', serif;
    font-size: 32px;
    line-height: 1.2;
    color: #1d1e20;
    margin-bottom: 16px;
  }

  .article__lead {
    font-size: 17px;
    line-height: 1.6;
    color: #555;
    margin-bottom: 12px;
  }

  .article__meta {
    font-size: 13px;
    color: #888;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .article__categories {
    display: flex;
    gap: 8px;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 12px;
  }

  .article__category {
    font-size: 11px;
    letter-spacing: 1.5px;
    color: #1f6d85;
    text-transform: uppercase;
    font-weight: 700;
  }

  .article__category:not(:last-child)::after {
    content: '·';
    margin-left: 8px;
    color: #ccc;
  }

  .article__image {
    width: 100%;
    height: auto;
    border-radius: 10px;
    margin-bottom: 32px;
  }

  .article__body {
    font-size: 16px;
    line-height: 1.75;
    color: #1d1e20;
  }

  .article__body :global(h2) {
    font-family: 'DM Sans', sans-serif;
    font-size: 22px;
    font-weight: 700;
    margin-top: 32px;
    margin-bottom: 14px;
    text-align: left;
  }

  .article__body :global(h3) {
    font-family: 'DM Sans', sans-serif;
    font-size: 18px;
    font-weight: 700;
    margin-top: 24px;
    margin-bottom: 12px;
    text-align: left;
  }

  .article__body :global(p) {
    margin-bottom: 16px;
    font-size: 16px;
  }

  .article__body :global(ul),
  .article__body :global(ol) {
    padding-left: 20px;
    margin-bottom: 16px;
  }

  .article__body :global(ul li) {
    list-style: disc;
    margin-left: 8px;
    margin-bottom: 8px;
    font-size: 16px;
  }

  .article__body :global(ol li) {
    list-style: decimal;
    margin-left: 8px;
    margin-bottom: 8px;
    font-size: 16px;
  }

  .article__body :global(a) {
    color: #1f6d85;
    text-decoration: underline;
  }

  .article__body :global(strong) {
    font-weight: 700;
  }

  .article__body :global(img) {
    border-radius: 10px;
    margin: 20px 0;
    max-width: 100%;
    height: auto;
  }

  .article__body p {
    margin-bottom: 16px;
    font-size: 16px;
  }

  .article__body ul, .article__body ol {
    padding-left: 20px;
    margin-bottom: 16px;
    list-style: disc;
  }

  .article__body ul li, .article__body ol li {
    margin-bottom: 8px;
    font-size: 16px;
    list-style: disc;
    margin-left: 8px;
  }

  .article__body ol li {
    list-style: decimal;
  }

  .article__body a {
    color: #1f6d85;
    text-decoration: underline;
  }

  .article__body a:hover {
    color: #164a5c;
  }

  .article__body strong {
    font-weight: 700;
  }

  .article__body img {
    border-radius: 10px;
    margin: 20px 0;
  }

  .article__cta {
    margin-top: 40px;
    padding-top: 32px;
    border-top: 1px solid #eee;
    text-align: center;
  }

  .article__cta-btn {
    display: inline-block;
    background: #1d1e20;
    color: #fff;
    padding: 14px 28px;
    border-radius: 10px;
    font-size: 12px;
    letter-spacing: 1.5px;
    font-weight: 700;
    text-decoration: none;
    margin-bottom: 20px;
  }

  .article__cta-link {
    display: block;
    color: #1f6d85;
    font-size: 14px;
    text-decoration: none;
  }

  @media (min-width: 768px) {
    .article__title { font-size: 42px; }
    .article { padding: 60px 40px; }
  }

  .location {
    background: #1f6d85;
    padding: 20px 24px 24px;
    color: #fff;
    text-align: center;
  }
  .location__title { font-size: 18px; font-weight: 500; margin-bottom: 4px; }
  .location__address { font-size: 14px; }
  .location__photo { width: 80%; max-width: 320px; margin: 12px auto 0; display: block; border-radius: 10px; }
  .footer__main { background: #1f6d85; padding: 24px; color: #fff; }
  .footer__logo { height: 30px; width: auto; margin: 0 auto 20px; display: block; }
  .footer__contact h3, .footer__hours h3 { font-size: 16px; font-weight: 500; margin-bottom: 8px; }
  .footer__contact p, .footer__hours p { font-size: 13px; line-height: 1.8; }
  .footer__hours { margin-top: 16px; }
  .footer__social { display: flex; gap: 16px; margin-top: 16px; color: #fff; }
  .footer__legal { font-size: 11px; margin-top: 16px; opacity: 0.7; border-top: 1px solid rgba(255,255,255,0.2); padding-top: 12px; }
  .footer__legal a { color: #fff; text-decoration: none; }
  .footer__legal a:hover { text-decoration: underline; }
</style>
