---
export const prerender = false;

import AdminLayout from '../../../layouts/AdminLayout.astro';
import { requireDb } from '../../../lib/db';

const sql = requireDb();
const { orderid } = Astro.params;

const rows = await sql`SELECT * FROM orders WHERE orderid = ${orderid}`;
if (rows.length === 0) {
  return new Response('Tellimust ei leitud', { status: 404 });
}
const order = rows[0];

function shippingLabel(val: string) {
  if (val === 'pickup') return 'Tule ise järgi (Sõle 14c, Tallinn)';
  if (val === 'dpd') return 'DPD pakiautomaat';
  if (val === 'omniva') return 'Omniva pakiautomaat';
  return val || '—';
}

const created = new Date(order.created_at).toLocaleString('et-EE', {
  day: 'numeric', month: 'long', year: 'numeric', hour: '2-digit', minute: '2-digit',
  timeZone: 'Europe/Tallinn',
});
---

<AdminLayout title={`Tellimus #${order.orderid}`} active="orders">
  <a href="/admin/tellimused" style="font-size:13px; color:#1f6d85;">← Kõik tellimused</a>
  <h1 style="margin-top:12px;">
    Tellimus #{order.orderid}
    <span class="badge badge--paid" style="vertical-align:middle; margin-left:8px;">Makstud</span>
    <span class={`badge ${order.fulfillment === 'fulfilled' ? 'badge--fulfilled' : 'badge--unfulfilled'}`} style="vertical-align:middle; margin-left:4px;" id="fulfillment-badge">
      {order.fulfillment === 'fulfilled' ? 'Täidetud' : 'Täitmata'}
    </span>
  </h1>
  <p style="color:#888; font-size:14px; margin-bottom:24px;">{created}</p>

  <div class="detail-grid">
    <div class="panel">
      <h2>Tooted</h2>
      <p style="font-size:15px; line-height:1.7;">{order.items || '—'}</p>
      <hr style="border:none; border-top:1px solid rgba(0,0,0,0.06); margin:16px 0;" />
      <table style="width:100%; font-size:14px;">
        <tr><td>Kokku</td><td style="text-align:right; font-weight:700;">€{Number(order.amount).toFixed(2)}</td></tr>
      </table>
      <p style="font-size:13px; color:#888; margin-top:12px;">Makseviis: {
        { paysera: 'Paysera', sularaha: 'Sularaha', ulekanne: 'Pangaülekanne', kaart: 'Kaardimakse kohapeal', muu: 'Muu' }[order.payment] || order.payment
      }</p>
    </div>

    <div class="panel">
      <h2>Klient</h2>
      <p style="font-size:15px; line-height:1.9;">
        {order.name}<br />
        <a href={`mailto:${order.email}`} style="color:#1f6d85;">{order.email}</a><br />
        {order.phone || ''}
      </p>
      <hr style="border:none; border-top:1px solid rgba(0,0,0,0.06); margin:16px 0;" />
      <p style="font-size:14px; line-height:1.8;">
        <strong>Saatmine:</strong> {shippingLabel(order.shipping)}<br />
        {order.parcel && <><strong>Pakiautomaat:</strong> {order.parcel}<br /></>}
        {order.address && <><strong>Aadress:</strong> {order.address}</>}
      </p>
    </div>
  </div>

  <div class="panel">
    <h2>Haldus</h2>
    <div style="display:flex; gap:12px; align-items:center; flex-wrap:wrap; margin-bottom:20px;">
      <button class="btn" id="toggle-fulfillment" data-current={order.fulfillment}>
        {order.fulfillment === 'fulfilled' ? 'MÄRGI TÄITMATA' : 'MÄRGI TÄIDETUKS'}
      </button>
    </div>
    <label for="note" style="font-size:13px; font-weight:500; display:block; margin-bottom:6px;">Märkmed</label>
    <textarea id="note" rows="3" style="width:100%; font-family:inherit; font-size:14px; padding:12px; border:1.5px solid rgba(0,0,0,0.12); border-radius:8px; outline:none; resize:vertical;">{order.note || ''}</textarea>
    <button class="btn btn--outline" id="save-note" style="margin-top:10px;">SALVESTA MÄRGE</button>
    <span id="save-status" style="font-size:13px; color:#1a7f37; margin-left:10px;"></span>
  </div>
</AdminLayout>

<script define:vars={{ orderid: order.orderid }}>
  const toggleBtn = document.getElementById('toggle-fulfillment');
  toggleBtn?.addEventListener('click', async () => {
    const next = toggleBtn.dataset.current === 'fulfilled' ? 'unfulfilled' : 'fulfilled';
    const res = await fetch('/api/admin/update-order', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ orderid, fulfillment: next }),
    });
    if (res.ok) window.location.reload();
  });

  document.getElementById('save-note')?.addEventListener('click', async () => {
    const note = document.getElementById('note').value;
    const res = await fetch('/api/admin/update-order', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ orderid, note }),
    });
    if (res.ok) {
      const s = document.getElementById('save-status');
      s.textContent = 'Salvestatud ✓';
      setTimeout(() => (s.textContent = ''), 2000);
    }
  });
</script>

<style>
  .detail-grid { display: grid; grid-template-columns: 1fr; gap: 24px; }
  @media (min-width: 900px) { .detail-grid { grid-template-columns: 1fr 1fr; } }
</style>
