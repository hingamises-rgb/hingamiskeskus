---
export const prerender = false;

import AdminLayout from '../../layouts/AdminLayout.astro';
import { requireDb } from '../../lib/db';

const sql = requireDb();
const days = Math.min(365, Math.max(7, parseInt(Astro.url.searchParams.get('days') || '30', 10)));

const [totals] = await sql`
  SELECT COALESCE(SUM(amount), 0) AS sales, COUNT(*) AS orders
  FROM orders WHERE created_at >= now() - make_interval(days => ${days})
`;
const sales = Number(totals.sales);
const orderCount = Number(totals.orders);
const aov = orderCount > 0 ? sales / orderCount : 0;

const daily = await sql`
  SELECT to_char(date_trunc('day', created_at AT TIME ZONE 'Europe/Tallinn'), 'YYYY-MM-DD') AS day, SUM(amount) AS total
  FROM orders WHERE created_at >= now() - make_interval(days => ${days})
  GROUP BY 1 ORDER BY 1
`;

// Toodete lõikes: parsi tellimuste sisu ("Toode x2, Teine x1") toodeteks
const orderItems = await sql`
  SELECT items FROM orders
  WHERE created_at >= now() - make_interval(days => ${days}) AND items IS NOT NULL AND items != ''
`;
const productMap = new Map<string, number>();
for (const row of orderItems) {
  for (const part of String(row.items).split(', ')) {
    const m = part.match(/^(.+?)\s+x(\d+)$/);
    const name = m ? m[1].trim() : part.trim();
    const qty = m ? parseInt(m[2], 10) : 1;
    if (!name) continue;
    productMap.set(name, (productMap.get(name) || 0) + qty);
  }
}
const topProducts = [...productMap.entries()]
  .map(([name, qty]) => ({ name, qty }))
  .sort((a, b) => b.qty - a.qty)
  .slice(0, 15);
const topQty = Math.max(...topProducts.map(p => p.qty), 1);

// SVG tulpdiagramm — päevavõtmed Tallinna ajavööndis
const W = 800, H = 220, PAD = 30;
const dayMap = new Map(daily.map(d => [d.day, Number(d.total)]));
function tallinnDay(offsetDays: number): string {
  return new Date(Date.now() - offsetDays * 86400_000)
    .toLocaleDateString('sv-SE', { timeZone: 'Europe/Tallinn' });
}
const series: { date: string; total: number }[] = [];
for (let i = days - 1; i >= 0; i--) {
  const key = tallinnDay(i);
  series.push({ date: key, total: dayMap.get(key) || 0 });
}
const maxVal = Math.max(...series.map(s => s.total), 1);
const barW = (W - PAD * 2) / series.length;

const periods = [
  { d: 30, label: '30 päeva' },
  { d: 90, label: '90 päeva' },
  { d: 365, label: 'Aasta' },
];
---

<AdminLayout title="Analüütika" active="analytics">
  <h1>Analüütika</h1>

  <div style="display:flex; gap:8px; margin-bottom:24px;">
    {periods.map(p => (
      <a href={`/admin/analuutika?days=${p.d}`}
         class={`period ${days === p.d ? 'period--active' : ''}`}>{p.label}</a>
    ))}
  </div>

  <div class="tiles">
    <div class="tile">
      <p class="tile__label">Müük ({days} päeva)</p>
      <p class="tile__value">€{sales.toFixed(2)}</p>
    </div>
    <div class="tile">
      <p class="tile__label">Tellimusi</p>
      <p class="tile__value">{orderCount}</p>
    </div>
    <div class="tile">
      <p class="tile__label">Keskmine tellimus</p>
      <p class="tile__value">€{aov.toFixed(2)}</p>
    </div>
  </div>

  <div class="panel">
    <h2>Müük päevade lõikes</h2>
    {orderCount === 0 ? (
      <p style="color:#888; font-size:14px;">Selle perioodi kohta andmeid pole veel.</p>
    ) : (
      <svg viewBox={`0 0 ${W} ${H}`} style="width:100%; height:auto;" role="img" aria-label="Müügi tulpdiagramm">
        {series.map((s, i) => {
          const h = (s.total / maxVal) * (H - PAD * 2);
          return (
            <rect
              x={PAD + i * barW + 1}
              y={H - PAD - h}
              width={Math.max(barW - 2, 1)}
              height={h}
              fill="#1f6d85"
              rx="2"
            >
              <title>{s.date}: €{s.total.toFixed(2)}</title>
            </rect>
          );
        })}
        <line x1={PAD} y1={H - PAD} x2={W - PAD} y2={H - PAD} stroke="rgba(0,0,0,0.15)" />
        <text x={PAD} y={H - 8} font-size="11" fill="#888">{series[0]?.date}</text>
        <text x={W - PAD} y={H - 8} font-size="11" fill="#888" text-anchor="end">{series[series.length - 1]?.date}</text>
        <text x={PAD} y={PAD - 8} font-size="11" fill="#888">max €{maxVal.toFixed(0)}</text>
      </svg>
    )}
  </div>

  <div class="panel">
    <h2>Populaarseimad tooted</h2>
    {topProducts.length === 0 ? (
      <p style="color:#888; font-size:14px;">Andmeid pole veel.</p>
    ) : (
      <div class="product-bars">
        {topProducts.map(p => (
          <div class="product-bar">
            <span class="product-bar__name">{p.name}</span>
            <div class="product-bar__track">
              <div class="product-bar__fill" style={`width:${(p.qty / topQty) * 100}%`}></div>
            </div>
            <span class="product-bar__qty">{p.qty} tk</span>
          </div>
        ))}
      </div>
    )}
  </div>
</AdminLayout>

<style>
  .period {
    font-size: 13px;
    font-weight: 500;
    padding: 8px 16px;
    border-radius: 999px;
    border: 1.5px solid #1f6d85;
    color: #1f6d85;
  }
  .period--active { background: #1f6d85; color: #fff; }

  .product-bars { display: flex; flex-direction: column; gap: 10px; }
  .product-bar { display: grid; grid-template-columns: 260px 1fr 60px; align-items: center; gap: 12px; font-size: 13px; }
  .product-bar__name { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .product-bar__track { background: #eef4f6; border-radius: 999px; height: 10px; overflow: hidden; }
  .product-bar__fill { background: #1f6d85; height: 100%; border-radius: 999px; }
  .product-bar__qty { color: #888; text-align: right; }
  @media (max-width: 700px) { .product-bar { grid-template-columns: 1fr; gap: 4px; } }
</style>
