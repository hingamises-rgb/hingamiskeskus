---
export const prerender = false;

import AdminLayout from '../../layouts/AdminLayout.astro';
import { requireDb } from '../../lib/db';

const sql = requireDb();
const days = Math.min(365, Math.max(7, parseInt(Astro.url.searchParams.get('days') || '30', 10)));

const [totals] = await sql`
  SELECT COALESCE(SUM(amount), 0) AS sales, COUNT(*) AS orders
  FROM orders WHERE created_at >= now() - make_interval(days => ${days})
`;
const sales = Number(totals.sales);
const orderCount = Number(totals.orders);
const aov = orderCount > 0 ? sales / orderCount : 0;

const daily = await sql`
  SELECT date_trunc('day', created_at AT TIME ZONE 'Europe/Tallinn')::date AS day, SUM(amount) AS total
  FROM orders WHERE created_at >= now() - make_interval(days => ${days})
  GROUP BY 1 ORDER BY 1
`;

const topItems = await sql`
  SELECT items, COUNT(*) AS cnt, SUM(amount) AS total
  FROM orders
  WHERE created_at >= now() - make_interval(days => ${days}) AND items IS NOT NULL AND items != ''
  GROUP BY items ORDER BY COUNT(*) DESC LIMIT 10
`;

// SVG tulpdiagramm
const W = 800, H = 220, PAD = 30;
const dayMap = new Map(daily.map(d => [new Date(d.day).toISOString().slice(0, 10), Number(d.total)]));
const series: { date: string; total: number }[] = [];
for (let i = days - 1; i >= 0; i--) {
  const d = new Date(Date.now() - i * 86400_000);
  const key = d.toISOString().slice(0, 10);
  series.push({ date: key, total: dayMap.get(key) || 0 });
}
const maxVal = Math.max(...series.map(s => s.total), 1);
const barW = (W - PAD * 2) / series.length;

const periods = [
  { d: 30, label: '30 päeva' },
  { d: 90, label: '90 päeva' },
  { d: 365, label: 'Aasta' },
];
---

<AdminLayout title="Analüütika" active="analytics">
  <h1>Analüütika</h1>

  <div style="display:flex; gap:8px; margin-bottom:24px;">
    {periods.map(p => (
      <a href={`/admin/analuutika?days=${p.d}`}
         class={`period ${days === p.d ? 'period--active' : ''}`}>{p.label}</a>
    ))}
  </div>

  <div class="tiles">
    <div class="tile">
      <p class="tile__label">Müük ({days} päeva)</p>
      <p class="tile__value">€{sales.toFixed(2)}</p>
    </div>
    <div class="tile">
      <p class="tile__label">Tellimusi</p>
      <p class="tile__value">{orderCount}</p>
    </div>
    <div class="tile">
      <p class="tile__label">Keskmine tellimus</p>
      <p class="tile__value">€{aov.toFixed(2)}</p>
    </div>
  </div>

  <div class="panel">
    <h2>Müük päevade lõikes</h2>
    {orderCount === 0 ? (
      <p style="color:#888; font-size:14px;">Selle perioodi kohta andmeid pole veel.</p>
    ) : (
      <svg viewBox={`0 0 ${W} ${H}`} style="width:100%; height:auto;" role="img" aria-label="Müügi tulpdiagramm">
        {series.map((s, i) => {
          const h = (s.total / maxVal) * (H - PAD * 2);
          return (
            <rect
              x={PAD + i * barW + 1}
              y={H - PAD - h}
              width={Math.max(barW - 2, 1)}
              height={h}
              fill="#1f6d85"
              rx="2"
            >
              <title>{s.date}: €{s.total.toFixed(2)}</title>
            </rect>
          );
        })}
        <line x1={PAD} y1={H - PAD} x2={W - PAD} y2={H - PAD} stroke="rgba(0,0,0,0.15)" />
        <text x={PAD} y={H - 8} font-size="11" fill="#888">{series[0]?.date}</text>
        <text x={W - PAD} y={H - 8} font-size="11" fill="#888" text-anchor="end">{series[series.length - 1]?.date}</text>
        <text x={PAD} y={PAD - 8} font-size="11" fill="#888">max €{maxVal.toFixed(0)}</text>
      </svg>
    )}
  </div>

  <div class="panel">
    <h2>Enim tellitud (tellimuse sisu järgi)</h2>
    {topItems.length === 0 ? (
      <p style="color:#888; font-size:14px;">Andmeid pole veel.</p>
    ) : (
      <table class="admin-table">
        <thead><tr><th>Tooted</th><th>Tellimusi</th><th>Käive</th></tr></thead>
        <tbody>
          {topItems.map(t => (
            <tr>
              <td>{t.items}</td>
              <td>{t.cnt}</td>
              <td>€{Number(t.total).toFixed(2)}</td>
            </tr>
          ))}
        </tbody>
      </table>
    )}
  </div>
</AdminLayout>

<style>
  .period {
    font-size: 13px;
    font-weight: 500;
    padding: 8px 16px;
    border-radius: 999px;
    border: 1.5px solid #1f6d85;
    color: #1f6d85;
  }
  .period--active { background: #1f6d85; color: #fff; }
</style>
