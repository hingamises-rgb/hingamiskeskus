---
export const prerender = false;

import AdminLayout from '../../../layouts/AdminLayout.astro';
import { requireDb } from '../../../lib/db';

const sql = requireDb();
const email = decodeURIComponent(Astro.params.email || '');

const orders = await sql`
  SELECT orderid, amount, fulfillment, items, shipping, parcel, created_at
  FROM orders WHERE email = ${email} ORDER BY created_at DESC
`;

if (orders.length === 0) {
  return new Response('Klienti ei leitud', { status: 404 });
}

const [info] = await sql`
  SELECT MAX(name) AS name, MAX(phone) AS phone, COUNT(*) AS order_count,
         SUM(amount) AS total, MIN(created_at) AS first_order, MAX(created_at) AS last_order
  FROM orders WHERE email = ${email}
`;

function fmtDate(d: string | Date) {
  return new Date(d).toLocaleDateString('et-EE', { timeZone: 'Europe/Tallinn' });
}
function fmtDateTime(d: string | Date) {
  return new Date(d).toLocaleString('et-EE', {
    day: 'numeric', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit',
    timeZone: 'Europe/Tallinn',
  });
}
---

<AdminLayout title={info.name || email} active="customers">
  <a href="/admin/kliendid" style="font-size:13px; color:#1f6d85;">← Kõik kliendid</a>
  <h1 style="margin-top:12px;">{info.name || email}</h1>
  <p style="color:#888; font-size:14px; margin-bottom:24px;">
    <a href={`mailto:${email}`} style="color:#1f6d85;">{email}</a>
    {info.phone && <> · {info.phone}</>}
  </p>

  <div class="tiles">
    <div class="tile">
      <p class="tile__label">Tellimusi kokku</p>
      <p class="tile__value">{info.order_count}</p>
    </div>
    <div class="tile">
      <p class="tile__label">Ostnud kokku</p>
      <p class="tile__value">€{Number(info.total).toFixed(2)}</p>
    </div>
    <div class="tile">
      <p class="tile__label">Esimene tellimus</p>
      <p class="tile__value" style="font-size:18px;">{fmtDate(info.first_order)}</p>
    </div>
    <div class="tile">
      <p class="tile__label">Viimane tellimus</p>
      <p class="tile__value" style="font-size:18px;">{fmtDate(info.last_order)}</p>
    </div>
  </div>

  <div class="panel">
    <h2>Kõik tellimused</h2>
    <table class="admin-table">
      <thead>
        <tr><th>Tellimus</th><th>Aeg</th><th>Tooted</th><th>Summa</th><th>Staatus</th></tr>
      </thead>
      <tbody>
        {orders.map(o => (
          <tr>
            <td><a href={`/admin/tellimused/${o.orderid}`}>#{o.orderid}</a></td>
            <td style="white-space:nowrap;">{fmtDateTime(o.created_at)}</td>
            <td>{o.items}</td>
            <td style="white-space:nowrap;">€{Number(o.amount).toFixed(2)}</td>
            <td>
              <span class={`badge ${o.fulfillment === 'fulfilled' ? 'badge--fulfilled' : 'badge--unfulfilled'}`}>
                {o.fulfillment === 'fulfilled' ? 'Täidetud' : 'Täitmata'}
              </span>
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</AdminLayout>
