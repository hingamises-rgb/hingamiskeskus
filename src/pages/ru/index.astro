<script>
  // Hero "Järgmine grupihingamine" uueneb automaatselt broneerimissüsteemi seansside järgi.
  // Kui API ei vasta või seansse pole, jääb HTML-i staatiline tekst (varutekst).
  (async () => {
    try {
      const res = await fetch('/api/booking/availability?type=group');
      if (!res.ok) return;
      const data = await res.json();
      const next = (data.sessions || [])[0];
      if (!next) return;
      const [y, m, d] = next.date.split('-');
      const el = document.getElementById('hero-event');
      if (el) el.textContent = `Следующая групповая дыхательная сессия состоится ${d}.${m} в ${next.time}`;
    } catch {}
  })();
</script>
