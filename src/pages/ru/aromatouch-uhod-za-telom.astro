---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import ContactForm from '../../components/ContactForm.astro';
import Footer from '../../components/Footer.astro';
import RelatedLinks from '../../components/RelatedLinks.astro';
---

<Layout
  title="Aromatouch уход за телом | Хингамискескус Таллин"
  description="Aromatouch уход за телом в Хингамискескус в Таллине. Расслабляющий массаж с эфирными маслами doTERRA снимает стресс и восстанавливает гармонию тела и разума!"
  keywords="Aromatouch уход за телом"
  lang="ru"
  alternates={{ et: '/aromatouch-kehahooldus', ru: '/ru/aromatouch-uhod-za-telom', en: '/en/aromatouch-body-treatment' }}
>

<!-- HEADER -->
<Header active="teenused" lang="ru" altHref="/aromatouch-kehahooldus" />

<!-- HERO SECTION (kogu tekst vasakul, pildid paremal) -->
<section class="float-hero">
  <div class="float-hero__content">
    <div class="float-hero__text">
      <h1 class="float-hero__title">Aromatouch уход за телом</h1>
      <h2 class="float-hero__subtitle">Терапевтический массаж с эфирными маслами doTERRA</h2>
      <p>Техника Aromatouch это нежный и расслабляющий уход за телом, который сочетает в себе полезные свойства эфирных масел doTERRA со специальными техниками прикосновений. Эта техника, напоминающая массаж, была разработана доктором Дэвидом Хиллом, специалистом в области эфирных масел и интегративной медицины.</p>
      <h2 class="float-info__heading">Основные характеристики и цели:</h2>
      <p><strong>Нежное прикосновение:</strong> Aromatouch это не интенсивный массаж, а мягкая и плавная техника прикосновений, направленная на расслабление нервной системы и всего тела.</p>
      <p><strong>Использование эфирных масел:</strong> Применяется специальный набор из 8 различных эфирных масел или их смесей от doTERRA. Эти масла отобраны за их терапевтические свойства и помогают сбалансировать тело как на физическом, так и на эмоциональном уровне.</p>
      <p>Масла оказывают успокаивающее, противовоспалительное, расслабляющее действие, а также поддерживают иммунную систему и улучшают настроение.</p>
      <p><strong>Балансировка тела:</strong> техника Aromatouch направлена на следующие эффекты:</p>
      <ul class="float-info__list">
        <li>Снижение стресса и тревожности.</li>
        <li>Укрепление иммунной системы и повышение устойчивости организма.</li>
        <li>Устранение воспалений и поддержка естественного восстановления организма.</li>
        <li>Расслабление мышц и улучшение кровообращения.</li>
      </ul>
      <p><strong>Работа с точками тела:</strong> в технике основное внимание уделяется позвоночнику, голове и ступням. Техника прикосновения стимулирует движение энергии в теле и активирует нервную систему.</p>
      <p><strong>Для тела и разума:</strong> Aromatouch это не только физический опыт, но и способ достичь ментального и эмоционального баланса. Эфирные масла в сочетании с мягкими прикосновениями создают чувство удовлетворения и глубокого расслабления.</p>
      <p>В итоге техника Aromatouch это деликатный способ расслабления и поддержки целительных процессов в организме. Она идеально подходит для тех, кто хочет улучшить своё самочувствие с помощью естественных и мягких методов. Эфирные масла проникают во все клетки тела всего за 20 секунд, воздействуя на лимфу, ткани и нервную систему, начиная оздоровление на клеточном уровне. Масла мягкими движениями наносятся на спину и ступни, вы сами можете выбрать, для поддержки какой системы организма вы хотите испытать ароматерапию. Несомненно, после сеанса вы почувствуете глубокое расслабление и спокойствие, а тело начнёт восстанавливать внутренний баланс.</p>
      <p><strong>Продолжительность сеанса:</strong> 60 минут</p>
      <p><strong>Цена:</strong> 50€</p>
    </div>
    <div class="float-hero__media">
      <img src="/images/aromatouch-naine.jpg" alt="Терапевт Aromatouch в Центре дыхания" class="float-hero__img" loading="lazy" />
      <img src="/images/aromatouch-kuunlad.jpg" alt="Массажная комната Aromatouch со свечами" class="float-hero__img" loading="lazy" style="margin-top: 24px;" />
    </div>
  </div>
</section>

<!-- BOOKING FORM -->
<ContactForm source="Aromatouch kehahooldus (RU)" lang="ru" />

<RelatedLinks lang="ru" links={[
