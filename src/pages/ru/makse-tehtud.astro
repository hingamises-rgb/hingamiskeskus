---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<Layout title="Оплата прошла успешно | Hingamiskeskus" lang="ru">

<Header active="epood" lang="ru" />

<section class="result">
  <h1>Спасибо за покупку!</h1>
  <p>Ваш платёж успешно принят. Мы свяжемся с вами по электронной почте.</p>
  <a href="/ru" class="result__btn">НА ГЛАВНУЮ</a>
</section>

<Footer lang="ru" />

<script is:inline>
  // Ostu sündmus reklaamikanalitele (kanali-ROAS). Summa tuleb kassast (hk_last_order),
  // käivitub üks kord tellimuse kohta — võti kustutatakse, et värskendus topelt ei saadaks.
  try {
    var raw = localStorage.getItem('hk_last_order');
    if (raw) {
      var order = JSON.parse(raw);
      var fresh = order && order.total > 0 && Date.now() - (order.ts || 0) < 3600e3;
      if (fresh) {
        if (typeof fbq === 'function') {
          fbq('track', 'Purchase', { value: Number(order.total), currency: 'EUR' });
        }
        if (typeof gtag === 'function') {
          gtag('event', 'purchase', {
            transaction_id: String(order.orderid || ''),
            value: Number(order.total),
            currency: 'EUR',
          });
        }
      }
      localStorage.removeItem('hk_last_order');
    }
  } catch (e) {}
</script>

</Layout>

<style>
  .header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 10px 16px; background: #fff; position: sticky; top: 0; z-index: 100;
    border-bottom: 1px solid rgba(0,0,0,0.05);
  }
  .header__logo img { height: 28px; width: auto; }
  .header__right { display: flex; align-items: center; gap: 16px; }
  .header__cart { color: #1d1e20; }
  .header__burger { display: flex; flex-direction: column; gap: 5px; padding: 4px; }
  .header__burger span { display: block; width: 22px; height: 2px; background: #1d1e20; }

  .result {
    padding: 80px 24px;
    text-align: center;
    max-width: 600px;
    margin: 0 auto;
  }
  .result h1 {
    font-size: 28px;
    margin-bottom: 16px;
    color: #1d1e20;
  }
  .result p {
    font-size: 16px;
    color: #555;
    margin-bottom: 32px;
    line-height: 1.6;
  }
  .result__btn {
    display: inline-block;
    background: #1d1e20;
    color: #fff;
    font-size: 12px;
    letter-spacing: 1.5px;
    padding: 14px 32px;
    border-radius: 10px;
  }

  .footer__main {
    background: #1f6d85; padding: 24px; color: #fff;
  }
  .footer__logo { height: 30px; width: auto; margin: 0 auto 20px; display: block; }
  .footer__contact h3 { font-size: 16px; font-weight: 500; margin-bottom: 8px; }
  .footer__contact p { font-size: 13px; line-height: 1.8; }
  .footer__legal {
    font-size: 11px; margin-top: 16px; opacity: 0.7;
    border-top: 1px solid rgba(255,255,255,0.2); padding-top: 12px;
  }
  .footer__legal a { color: #fff; text-decoration: none; }
</style>
