---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import { requireDb } from '../../lib/db';
import Footer from '../../components/Footer.astro';

// Tooted loetakse build'i ajal andmebaasist — admin paneelis tehtud
// muudatused jõustuvad e-poes järgmise deploy'ga.
const sql = requireDb();
const allProducts = await sql`
  SELECT slug, page_slug_ru, COALESCE(title_ru, title) AS title, COALESCE(alt_ru, alt) AS alt,
         image, cart_name, price, old_price,
         CASE WHEN price_prefix = 'Al.' THEN 'от' ELSE price_prefix END AS price_prefix,
         category, sold_out
  FROM products WHERE active = true ORDER BY sort, slug
`;

const CATEGORIES = [
  { id: 'kinkekaardid', title: 'Подарочные карты' },
  { id: 'paketid', title: 'Пакеты' },
  { id: 'vitamiinid', title: 'Витамины' },
  { id: 'epsomi-sool', title: 'Соль Эпсома' },
];

const byCategory = new Map(CATEGORIES.map(c => [c.id, []]));
for (const p of allProducts) {
  if (byCategory.has(p.category)) byCategory.get(p.category).push(p);
}

function fmtPrice(v: unknown) {
  return `€${Number(v).toFixed(2)}`;
}

// Ostukorvi jaoks: slug -> { name, price }. Nimi venekeelne (title_ru) —
// kasutaja lisab Make'i kinkekaardi-automaatikasse venekeelsed read ise.
const PRODUCTS_DATA: Record<string, { name: string; price: number }> = {};
for (const p of allProducts) {
  if (!p.sold_out) PRODUCTS_DATA[p.slug] = { name: p.title, price: Number(p.price) };
}
---

<Layout
  title="Интернет-магазин Хингамискескус: соль Эпсома, витамины и пакеты"
  description="Интернет-магазин Хингамискескус предлагает соль Эпсома, витамины и пакеты для расслабления. У нас есть подарочные карты и товары для восстановления тела и снятия стресса."
  keywords="соль Эпсома, пакеты, интернет-магазин Хингамискескус"
  lang="ru"
  alternates={{ et: '/e-pood', ru: '/ru/onlajn-shop', en: '/en/shop' }}
>

<!-- HEADER -->
<Header active="epood" lang="ru" altHref="/e-pood" />

<!-- PAGE TITLE -->
<section class="page-hero">
  <h1 class="page-hero__title">Интернет-магазин</h1>
</section>

<!-- CATEGORY NAV -->
<nav class="cat-nav">
  <a href="#kinkekaardid" class="cat-nav__btn">ПОДАРОЧНЫЕ КАРТЫ</a>
  <a href="#paketid" class="cat-nav__btn">ПАКЕТЫ</a>
  <a href="#vitamiinid" class="cat-nav__btn">ВИТАМИНЫ</a>
  <a href="#epsomi-sool" class="cat-nav__btn">СОЛЬ ЭПСОМА</a>
</nav>

<!-- INTRO TEXT -->
<section class="shop-intro">
  <h2 class="shop-intro__heading">Интернет-магазин Центра дыхания</h2>
  <p>В интернет-магазине Центра дыхания ты найдёшь всё, что поддерживает твоё благополучие и расслабление как дома, так и в нашем центре.</p>

  <h3 class="shop-intro__subheading">Подарочные карты и пакеты</h3>
  <p>Все наши подарочные карты и пакеты можно гибко использовать как для сеансов флоатинга, так и для сеансов освобождающего дыхания. Каждый раз ты сам выбираешь, какой опыт тебе нужен. Карты на несколько сеансов можно использовать внутри семьи, по одной карте сеансы могут бронировать и другие члены семьи.</p>
  <p><strong>Подарочные карты</strong> это отличный подарок близким. Отправим карту на электронную почту, или при желании можешь сам забрать физическую карту. Карты действительны 6 месяцев.</p>

  <h3 class="shop-intro__subheading">Соль Эпсома</h3>
  <p>В нашем магазине пять разных видов соли Эпсома: чистая соль и варианты с эфирными маслами, которые делают домашнюю ванну особенно расслабляющей и приятно пахнущей. Соль Эпсома содержит магний, который помогает расслабить мышцы, успокаивает нервную систему и способствует лучшему сну. Идеальный выбор для ежедневного восстановления и расслабления дома.</p>
</section>

<!-- TOOTED (andmebaasist, kategooriate kaupa) -->
{CATEGORIES.map(cat => (
  <section class="product-section" id={cat.id}>
    <h2 class="product-section__title">{cat.title}</h2>
    <div class="product-grid">
      {byCategory.get(cat.id).map(p => (
        p.sold_out ? (
          <div class="product-card product-card--sold-out">
            <div class="product-card__ribbon">SOLD OUT</div>
            <a href={p.page_slug_ru ? `/ru/${p.page_slug_ru}` : '/ru/onlajn-shop'} class="product-card__link">
              <img src={p.image} alt={p.alt} class="product-card__img" loading="lazy" />
              <h3 class="product-card__title">{p.title}</h3>
            </a>
            <p class="product-card__price product-card__price--sold-out">Sold out</p>
          </div>
        ) : (
          <div class="product-card">
            <a href={p.page_slug_ru ? `/ru/${p.page_slug_ru}` : '/ru/onlajn-shop'} class="product-card__link">
              <img src={p.image} alt={p.alt} class="product-card__img" loading="lazy" />
              <h3 class="product-card__title">{p.title}</h3>
            </a>
            <p class="product-card__price">{p.price_prefix ? p.price_prefix + ' ' : ''}{p.old_price && <><span class="price--old">{fmtPrice(p.old_price)}</span>{' '}</>}{fmtPrice(p.price)}</p>
            <button class="product-card__btn" data-product={p.slug}>В КОРЗИНУ</button>
          </div>
        )
      ))}
    </div>
  </section>
))}

<Footer lang="ru" />

</Layout>

<script is:inline define:vars={{ PRODUCTS_DATA }}>
  const PRODUCTS = PRODUCTS_DATA;

  function getCart() {
    try { return JSON.parse(localStorage.getItem('hk_cart') || '[]'); }
    catch { return []; }
  }

  function saveCart(cart) {
    localStorage.setItem('hk_cart', JSON.stringify(cart));
    updateBadge();
  }

  function updateBadge() {
    const cart = getCart();
    const count = cart.reduce(function(s, i) { return s + i.qty; }, 0);
    let badge = document.querySelector('.cart-badge');
    if (count > 0) {
      if (!badge) {
        badge = document.createElement('span');
        badge.className = 'cart-badge';
        document.querySelector('.header__cart').appendChild(badge);
      }
      badge.textContent = count;
    } else if (badge) {
      badge.remove();
    }
  }

  function addToCart(productId) {
    const product = PRODUCTS[productId];
    if (!product) return;
    const cart = getCart();
    const existing = cart.find(function(item) { return item.id === productId; });
    if (existing) {
      existing.qty += 1;
    } else {
      cart.push({ id: productId, name: product.name, price: product.price, qty: 1 });
    }
    saveCart(cart);
  }

  document.querySelectorAll('.product-card__btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var productId = this.getAttribute('data-product');
      addToCart(productId);
      this.textContent = 'ДОБАВЛЕНО ✓';
      var self = this;
      setTimeout(function() { self.textContent = 'В КОРЗИНУ'; }, 1500);
    });
  });

  updateBadge();
</script>

<style>
  /* HEADER */
  .header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 16px;
    background: #fff;
    position: sticky;
    top: 0;
    z-index: 100;
    border-bottom: 1px solid rgba(0,0,0,0.05);
  }
  .header__logo img { height: 28px; width: auto; }
  .header__right { display: flex; align-items: center; gap: 16px; }
  .header__cart { color: #1d1e20; position: relative; }
  :global(.cart-badge) {
    position: absolute;
    top: -6px;
    right: -8px;
    background: #1f6d85;
    color: #fff;
    font-size: 10px;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
  }
  .header__burger {
    display: flex;
    flex-direction: column;
    gap: 5px;
    padding: 4px;
  }
  .header__burger span {
    display: block;
    width: 22px;
    height: 2px;
    background: #1d1e20;
  }

  /* PAGE HERO */
  .page-hero {
    background: #f3fcff;
    padding: 40px 24px;
    text-align: center;
  }
  .page-hero__title {
    font-size: 32px;
    font-weight: 400;
  }

  /* CATEGORY NAV */
  .cat-nav {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 24px 16px;
    background: #fff;
  }
  .cat-nav__btn {
    display: block;
    background: #1d1e20;
    color: #fff;
    font-size: 14px;
    letter-spacing: 1.5px;
    padding: 16px 20px;
    border-radius: 10px;
    text-align: center;
    outline: none;
    -webkit-tap-highlight-color: transparent;
  }

  /* SHOP INTRO */
  .shop-intro {
    padding: 0 24px 32px;
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
  }
  .shop-intro__heading {
    font-size: 20px;
    font-weight: 700;
    margin-bottom: 8px;
  }
  .shop-intro__subheading {
    font-size: 18px;
    font-weight: 700;
    margin-top: 20px;
    margin-bottom: 6px;
  }
  .shop-intro p {
    font-size: 18px;
    color: #333;
    line-height: 1.7;
    margin-bottom: 8px;
  }

  /* PRODUCT SECTION */
  .product-section {
    padding: 32px 16px;
    scroll-margin-top: 60px;
  }
  .product-section:nth-child(even) {
    background: #f3fcff;
  }
  .product-section__title {
    text-align: center;
    font-size: 28px;
    font-weight: 400;
    margin-bottom: 24px;
    color: #1d1e20;
  }

  /* PRODUCT GRID */
  .product-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
    max-width: 1200px;
    margin: 0 auto;
  }

  /* PRODUCT CARD */
  .product-card {
    text-align: center;
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }
  /* Nupp alati kaardi allservas — kahe reaga pealkiri ei aja rida paigast */
  .product-card__btn { margin-top: auto; align-self: center; }
  .product-card__title { min-height: calc(2 * 1.4em + 16px); }
  .product-card__ribbon {
    position: absolute;
    top: 12px;
    left: 12px;
    background: #1d1e20;
    color: #fff;
    font-size: 11px;
    letter-spacing: 1px;
    padding: 6px 12px;
    border-radius: 4px;
    z-index: 2;
  }
  .product-card__img {
    width: 100%;
    display: block;
    border-radius: 0;
    clip-path: inset(0 round 10px);
  }
  #paketid .product-card__img {
    aspect-ratio: 768/431;
    object-fit: cover;
  }
  #kinkekaardid .product-card__img {
    aspect-ratio: 768/431;
    object-fit: cover;
  }
  #vitamiinid .product-card__img {
    aspect-ratio: 400/768;
    object-fit: cover;
  }
  #epsomi-sool .product-card__img {
    aspect-ratio: 1/1;
    object-fit: cover;
  }
  .product-card--sold-out .product-card__img {
    opacity: 0.6;
  }
  .product-card__title {
    font-size: 16px;
    font-weight: 400;
    padding: 12px 8px 4px;
    line-height: 1.4;
  }
  .product-card__price {
    font-size: 16px;
    color: #1d1e20;
    padding: 4px 0 12px;
  }
  .product-card__price--sold-out {
    color: #999;
    font-style: italic;
  }
  .price--old {
    text-decoration: line-through;
    color: #999;
    margin-right: 4px;
  }
  .product-card__btn {
    display: inline-block;
    background: #1d1e20;
    color: #fff;
    font-size: 12px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    padding: 12px 28px;
    border-radius: 10px;
    border: none;
    cursor: pointer;
    font-family: 'DM Sans', sans-serif;
  }
  .product-card__btn:hover {
    background: #333;
  }

  /* LOCATION */
  .location {
    background: #1f6d85;
    padding: 20px 24px 24px;
    color: #fff;
    text-align: center;
  }
  .location__title {
    font-size: 18px;
    font-weight: 500;
    margin-bottom: 4px;
  }
  .location__address {
    font-size: 14px;
  }
  .location__photo {
    width: 80%;
    max-width: 320px;
    margin: 12px auto 0;
    display: block;
    border-radius: 10px;
  }

  /* FOOTER */
  .footer__main {
    background: #1f6d85;
    padding: 24px;
    color: #fff;
  }
  .footer__logo {
    height: 30px;
    width: auto;
    margin: 0 auto 20px;
    display: block;
  }
  .footer__contact h3,
  .footer__hours h3 {
    font-size: 16px;
    font-weight: 500;
    margin-bottom: 8px;
  }
  .footer__contact p,
  .footer__hours p {
    font-size: 18px;
    line-height: 1.8;
  }
  .footer__hours {
    margin-top: 16px;
  }
  .footer__social {
    display: flex;
    gap: 16px;
    margin-top: 16px;
    color: #fff;
  }
  .footer__legal {
    font-size: 11px;
    margin-top: 16px;
    opacity: 0.7;
    border-top: 1px solid rgba(255,255,255,0.2);
    padding-top: 12px;
  }
  .footer__legal a:hover { text-decoration: underline; }

  /* DESKTOP */
  @media (min-width: 768px) {
    .page-hero { padding: 72px 40px; }
    .page-hero__title { font-size: 58px; font-weight: 600; }

    .header { padding: 12px 40px; }
    .header__logo img { height: 36px; }
    .cat-nav { flex-direction: row; flex-wrap: wrap; justify-content: center; padding: 32px 40px; gap: 16px; }
    .cat-nav__btn { display: inline-block; width: auto; font-size: 13px; padding: 14px 28px; }
    .shop-intro { padding: 0 40px 40px; }
    .product-section { padding: 40px; }
    .product-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
    }
    .product-card__title { font-size: 18px; }
  }
</style>
