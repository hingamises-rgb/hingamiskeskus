---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
---

<Layout title="Makse ebaõnnestus | Hingamiskeskus">

<Header active="epood" />

<section class="result">
  <h1>Makse ebaõnnestus</h1>
  <p>Kahjuks makse ei õnnestunud. Palun proovi uuesti või võta meiega ühendust.</p>
  <a href="/e-pood" class="result__btn">TAGASI E-POODI</a>
</section>

<footer class="footer">
  <div class="footer__main">
    <img src="/images/logo-valge.png" alt="Hingamiskeskus" class="footer__logo" />
    <div class="footer__contact">
      <h3>Kontakt</h3>
      <p>E-post: Info@hingamiskeskus.ee</p>
      <p>Telefoninumber:</p>
      <p>+372 56695898</p>
      <p>+372 56497689</p>
    </div>
    <div class="footer__legal">
      <a href="/privaatsuspoliitika">Privaatsuspoliitika</a> | <a href="/muugitingimused">Müügitingimused</a>
    </div>
  </div>
</footer>

</Layout>

<style>
  .header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 10px 16px; background: #fff; position: sticky; top: 0; z-index: 100;
    border-bottom: 1px solid rgba(0,0,0,0.05);
  }
  .header__logo img { height: 28px; width: auto; }
  .header__right { display: flex; align-items: center; gap: 16px; }
  .header__cart { color: #1d1e20; }
  .header__burger { display: flex; flex-direction: column; gap: 5px; padding: 4px; }
  .header__burger span { display: block; width: 22px; height: 2px; background: #1d1e20; }

  .result {
    padding: 80px 24px;
    text-align: center;
    max-width: 600px;
    margin: 0 auto;
  }
  .result h1 {
    font-size: 28px;
    margin-bottom: 16px;
    color: #1d1e20;
  }
  .result p {
    font-size: 16px;
    color: #555;
    margin-bottom: 32px;
    line-height: 1.6;
  }
  .result__btn {
    display: inline-block;
    background: #1d1e20;
    color: #fff;
    font-size: 12px;
    letter-spacing: 1.5px;
    padding: 14px 32px;
    border-radius: 10px;
  }

  .footer__main {
    background: #1f6d85; padding: 24px; color: #fff;
  }
  .footer__logo { height: 30px; width: auto; margin: 0 auto 20px; display: block; }
  .footer__contact h3 { font-size: 16px; font-weight: 500; margin-bottom: 8px; }
  .footer__contact p { font-size: 13px; line-height: 1.8; }
  .footer__legal {
    font-size: 11px; margin-top: 16px; opacity: 0.7;
    border-top: 1px solid rgba(255,255,255,0.2); padding-top: 12px;
  }
  .footer__legal a { color: #fff; text-decoration: none; }
</style>
