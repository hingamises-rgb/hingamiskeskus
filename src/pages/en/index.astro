---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<Layout
  title="breathwork floating in Tallinn | Hingamiskeskus"
  description="Discover breathwork floating in Tallinn at Hingamiskeskus. Experience floating with Epsom salt water and breathwork sessions to relieve stress and find deep relaxation!"
  keywords="Floating magneesiumsoolvees, breathwork floating in Tallinn"
  lang="en"
  alternates={{ et: '/', ru: '/ru', en: '/en' }}
>

<!-- HEADER -->
<Header active="avaleht" lang="en" />

<!-- HERO -->
<section class="hero">
  <img src="/images/hero-bg.jpg" alt="Breathwork at Hingamiskeskus" class="hero__bg" loading="eager" />
  <div class="hero__overlay"></div>
  <div class="hero__content">
    <h1 class="hero__title">Insomnia, stress and tension?<br />Breathwork and floating in Tallinn can help</h1>
    <p class="hero__event" id="hero-event">The next group breathing session will take place on 14.07 at 18:00</p>
    <a href="/en/book-a-session" class="hero__register">REGISTER FOR THE GROUP BREATHING SESSION HERE!</a>
    <a href="/en/trial-package-3x" class="hero__cta-btn">3X TRIAL PACKAGE SPECIAL PRICE 75€ (REGULAR PRICE 120€)</a>
    <div class="hero__services">
      <a href="/en/breathwork" class="hero__service-btn">BREATHWORK</a>
      <a href="/en/floating" class="hero__service-btn">FLOATING</a>
      <a href="/en/shop" class="hero__service-btn hero__service-btn--center">SHOP</a>
    </div>
  </div>
</section>

<!-- PAIK MIS ON LOODUD -->
<section class="intro">
  <div class="intro__cols">
    <div class="intro__body">
      <h2 class="intro__title">A place created for relaxation and peace of mind</h2>
      <p class="intro__text">We offer the opportunity to experience how conscious breathing and floating together create the ideal conditions for mind and body relaxation.</p>
      <p class="intro__text">This is a place where the hustle and bustle of everyday life are replaced by silence and peace, providing a chance to turn inward and experience true well-being.</p>
      <p class="intro__text">Conscious breathing sessions are designed to relieve stress and achieve inner peace. Floating offers a unique opportunity for the body and mind to rest in a weightless state. Together, these therapies form a powerful duo that supports both physical and mental health. Conscious breathing and floating help restore energy, improve sleep, and elevate mood.</p>
      <p class="intro__text">Every detail in our center is designed to provide the best possible experience!</p>
    </div>
    <img src="/images/terapeut.jpg" alt="Breathwork session at Hingamiskeskus" class="intro__photo" loading="lazy" />
  </div>
</section>

<!-- MIS ON VABASTAV HINGAMINE -->
<section class="about">
  <h2 class="about__title">What is conscious breathing?</h2>
  <p class="about__text">The origins of conscious breathing can be traced back thousands of years, linking it to the pranayama breathing techniques of ancient Indian yogis, the shamanic rituals of South America, Australia, and Africa, as well as the Chinese Qi Gong practices.</p>
  <p class="about__text">For millennia, conscious breathing techniques have been used to cleanse the body and mind, achieving balance and harmony in consciousness.</p>
  <p class="about__text">Modern breathwork emerged in the awakening 1960s through <em>holotropic</em> and rebirthing breath therapy. The rediscovered and experimented techniques of that era paved the way for spiritual awakening and healing, which was in high demand at the time.</p>
  <p class="about__text">For the first time, psychology was integrated into everyday life through various conscious breathing methods.</p>
  <p class="about__text">In the last decade, different breathing techniques have gained significant attention as people have once again become interested in inner growth and methods for spiritual and physical healing.</p>
  <p class="about__text">The accelerated breathing practiced during breathwork sessions leads a person into a state of expanded consciousness, allowing suppressed traumas, thoughts, tensions, and emotions to be released.</p>
</section>

<!-- 6 KASU IKOONI -->
<section class="benefits">
  <div class="benefit">
    <img src="/images/icon-puhastab.png" alt="Cleanses the body" class="benefit__icon" loading="lazy" />
    <h3 class="benefit__title">Cleanses the body</h3>
    <p class="benefit__text">With accelerated and deep breaths, the body is cleansed of <strong>unnecessary waste products</strong></p>
  </div>
  <div class="benefit">
    <img src="/images/icon-stress.png" alt="Reduces stress" class="benefit__icon" loading="lazy" />
    <h3 class="benefit__title">Reduces stress</h3>
    <p class="benefit__text">A calm environment leads you into a <strong>meditative state</strong>, where your stress levels naturally decrease</p>
  </div>
  <div class="benefit">
    <img src="/images/icon-emotsioonid.png" alt="Releases emotions from the body" class="benefit__icon" loading="lazy" />
    <h3 class="benefit__title">Releases emotions from the body</h3>
    <p class="benefit__text">People <strong>subconsciously suppress their emotions</strong>, which can lead to irritability or tension</p>
  </div>
  <div class="benefit">
    <img src="/images/icon-uni.png" alt="Improves sleep quality" class="benefit__icon" loading="lazy" />
    <h3 class="benefit__title">Improves sleep quality</h3>
    <p class="benefit__text">Breathing exercises <strong>release tension from the body</strong> and <strong>calm the central nervous system</strong>, helping to alleviate insomnia</p>
  </div>
  <div class="benefit">
    <img src="/images/icon-keskendumis.png" alt="Improves concentration" class="benefit__icon" loading="lazy" />
    <h3 class="benefit__title">Improves concentration</h3>
    <p class="benefit__text">A meditative state enhances concentration and <strong>the ability to focus</strong></p>
  </div>
  <div class="benefit">
    <img src="/images/icon-aeg.png" alt="Take a break from everyday life" class="benefit__icon" loading="lazy" />
    <h3 class="benefit__title">Take a break from everyday life</h3>
    <p class="benefit__text">A great way to relax and <strong>take time for yourself</strong></p>
  </div>
</section>

<!-- TEAL CTA -->
<section class="cta-ribbon">
  <h2 class="cta-ribbon__title">Book your session today</h2>
  <a href="/en/book-a-session" class="cta-ribbon__btn">HERE</a>
</section>

<!-- KOGE UUT ELUKVALITEETI -->
<section class="experience">
  <div class="experience__cols">
    <div class="experience__body">
      <h2 class="experience__heading">Experience a new quality of life</h2>
      <p class="experience__subheading">Reach a healthier you through conscious breathing and floating</p>
      <p class="experience__text">Hingamiskeskus is the only place in Estonia where you can experience floating and conscious breathing in a single session. Conscious breathing is a scientifically proven practice, extensively studied for its beneficial effects on people. It is a guided session led by an experienced therapist, directing individuals into a deep meditative state. As the name suggests, this practice helps alleviate anxiety, release heavy emotions, and heal past traumas.</p>
      <a href="/en/breathwork" class="experience__btn">READ MORE</a>
    </div>
    <img src="/images/aromatouch-naine.jpg" alt="Hingamiskeskus therapist" class="experience__photo" loading="lazy" />
  </div>
</section>

<!-- TAGASISIDE -->
<section class="testimonials">
  <h2 class="testimonials__title">Read what visitors say about their experience</h2>
  <div class="testimonials__cols">
    <div class="testimonial">
      <p class="testimonial__text">I had a one-hour floating session in late pregnancy. It was my second time experiencing it, and it was an incredibly pleasant and relaxing experience. It felt great to float weightlessly in the warm water, especially with the extra weight of pregnancy. After the session, I felt a deep sense of calm and had an excellent night&#39;s sleep. I also appreciated that I had the option to keep the light on and leave the lid open, so there was no need to worry about darkness or feeling enclosed. Overall, I was very satisfied with the experience and highly recommend it to other pregnant women as well.</p>
      <p class="testimonial__author">MARITE</p>
    </div>
    <div class="testimonial">
      <p class="testimonial__text">Conscious breathing always gives me a pleasant reset. My mind feels fresher and clearer. I have always followed my intuition when deciding to join a session whether something is bothering me or when I feel anxious or heavy. For me, breathwork and daily mindful breathing are the first steps in bringing order to my inner world. It forms the foundation for good health and a brighter everyday life.</p>
      <p class="testimonial__recommend">I definitely recommend it!</p>
      <p class="testimonial__author">KRISTI MERIVÄLI</p>
    </div>
  </div>
</section>

<!-- KOOSTÖÖPARTNERID -->
<section class="partners">
  <h2 class="partners__title">PARTNERS</h2>
  <div class="partners__grid">
    <a href="https://kaia.ee/" target="_blank" rel="noopener"><img src="/images/partner-kehakool.png" alt="K.Heinleht Kehakool" loading="lazy" /></a>
    <a href="https://lumiorav.ee/" target="_blank" rel="noopener"><img src="/images/partner-lumiorav.png" alt="Lumiorav" loading="lazy" /></a>
    <a href="https://teadlik-loomine.ee/" target="_blank" rel="noopener"><img src="/images/partner-akadeemia.png" alt="Teadliku Loomise ja Hingamise Akadeemia" loading="lazy" /></a>
    <a href="https://www.spiritstudio.ee/et" target="_blank" rel="noopener"><img src="/images/partner-spirit.png" alt="Spirit Studio" loading="lazy" /></a>
    <a href="https://villjasall.ee/" target="_blank" rel="noopener"><img src="/images/partner-villjasall.png" alt="Vill ja Sall — käsitöölõngad ja sallid" loading="lazy" class="partners__img--dark" /></a>
  </div>
</section>

<Footer lang="en" />

</Layout>

<style>
  /* HEADER */
  .header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 16px;
    background: #fff;
    position: sticky;
    top: 0;
    z-index: 100;
    border-bottom: 1px solid rgba(0,0,0,0.05);
  }
  .header__logo img { height: 28px; width: auto; }
  .header__right { display: flex; align-items: center; gap: 16px; }
  .header__cart { color: #1d1e20; }
  .header__burger {
    display: flex;
    flex-direction: column;
    gap: 5px;
    padding: 4px;
  }
  .header__burger span {
    display: block;
    width: 22px;
    height: 2px;
    background: #1d1e20;
  }

  /* HERO */
  .hero {
    position: relative;
    min-height: 520px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .hero__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .hero__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.35);
  }
  .hero__content {
    position: relative;
    z-index: 1;
    text-align: center;
    padding: 32px 24px;
    width: 100%;
  }
  .hero__title {
    font-size: 34px;
    font-weight: 500;
    color: #fff;
    line-height: 1.2;
    margin-bottom: 20px;
    max-width: 14ch;
    margin-left: auto;
    margin-right: auto;
  }
  .hero__event {
    font-size: 19px;
    font-weight: 500;
    color: #fff;
    line-height: 1.35;
    margin-bottom: 12px;
    max-width: 24ch;
    margin-left: auto;
    margin-right: auto;
  }
  .hero__register {
    display: inline-block;
    font-size: 12px;
    color: #fff;
    letter-spacing: 2px;
    text-transform: uppercase;
    background: rgba(255,255,255,0.16);
    padding: 9px 18px;
    margin-bottom: 24px;
  }
  .hero__cta-btn {
    display: block;
    background: #3b3b3b;
    color: #fff;
    font-size: 12px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    padding: 20px 18px;
    margin-bottom: 14px;
    border-radius: 10px;
  }
  .hero__services {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-bottom: 8px;
    justify-content: center;
  }
  .hero__service-btn {
    flex: 1 1 40%;
    background: #0d0d0d;
    color: #fff;
    font-size: 12px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    padding: 16px 10px;
    text-align: center;
    border-radius: 6px;
  }
  .hero__service-btn--center {
    flex: 0 0 50%;
  }

  /* INTRO */
  .intro {
    background: #fff;
    padding: 32px 24px;
    text-align: center;
  }
  .intro__title {
    font-size: 20px;
    font-weight: 500;
    color: #1d1e20;
    line-height: 1.3;
    margin-bottom: 16px;
  }
  .intro__text {
    font-size: 18px;
    color: #555;
    line-height: 1.7;
    margin-bottom: 14px;
  }
  .intro__photo {
    width: 100%;
    max-width: 430px;
    border-radius: 8px;
    display: block;
    margin: 8px auto 0;
  }

  /* ABOUT */
  .about {
    background: #f3fcff;
    padding: 32px 24px;
    text-align: center;
  }
  .about__title {
    font-size: 20px;
    font-weight: 500;
    margin-bottom: 20px;
  }
  .about__text {
    font-size: 18px;
    color: #555;
    line-height: 1.7;
    margin-bottom: 14px;
  }

  /* BENEFITS */
  .benefits {
    background: #f3fcff;
    padding: 16px 24px 32px;
    text-align: center;
  }
  .benefit {
    margin-bottom: 28px;
  }
  .benefit:last-child { margin-bottom: 0; }
  .benefit__icon {
    width: 55px;
    height: auto;
    margin: 0 auto 10px;
  }
  .benefit__title {
    font-size: 20px;
    font-weight: 500;
    margin-bottom: 6px;
  }
  .benefit__text {
    font-size: 18px;
    color: #555;
    line-height: 1.6;
  }

  /* CTA RIBBON */
  .cta-ribbon {
    background: #1f6d85;
    padding: 28px 24px;
    text-align: center;
  }
  .cta-ribbon__title {
    font-size: 22px;
    font-weight: 500;
    color: #fff;
    margin-bottom: 16px;
  }
  .cta-ribbon__btn {
    display: inline-block;
    border: 1.5px solid #fff;
    color: #fff;
    font-size: 14px;
    letter-spacing: 2px;
    text-transform: uppercase;
    padding: 12px 32px;
  }

  /* EXPERIENCE */
  .experience {
    background: #fff;
    padding: 32px 24px;
    text-align: center;
  }
  .experience__heading {
    font-size: 20px;
    font-weight: 500;
    letter-spacing: 0.5px;
    margin-bottom: 4px;
  }
  .experience__subheading {
    font-size: 16px;
    margin-bottom: 20px;
  }
  .experience__photo {
    width: 80%;
    max-width: 430px;
    border-radius: 8px;
    margin: 20px auto 0;
    display: block;
  }
  .experience__text {
    font-size: 18px;
    color: #555;
    line-height: 1.7;
    margin-bottom: 20px;
  }
  .experience__btn {
    display: inline-block;
    background: #1f6d85;
    color: #fff;
    font-size: 13px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    padding: 14px 32px;
  }

  /* TESTIMONIALS */
  .testimonials {
    background: #1f6d85;
    padding: 32px 24px;
    text-align: center;
    color: #fff;
  }
  .testimonials__title {
    font-size: 20px;
    font-weight: 500;
    margin-bottom: 24px;
  }
  .testimonial {
    margin-bottom: 28px;
  }
  .testimonial:last-child { margin-bottom: 0; }
  .testimonial__text {
    font-size: 18px;
    line-height: 1.7;
    margin-bottom: 12px;
  }
  .testimonial__recommend {
    font-size: 14px;
    margin-bottom: 8px;
  }
  .testimonial__author {
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 1px;
  }

  /* PARTNERS */
  .partners {
    background: #fff;
    padding: 32px 24px;
    text-align: center;
  }
  .partners__title {
    font-size: 18px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 2px;
    margin-bottom: 24px;
  }
  .partners__grid {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
  }
  .partners__grid img {
    max-width: 280px;
    height: auto;
  }
  .partners__grid img.partners__img--dark {
    max-width: 170px;
    border-radius: 10px;
  }

  /* DESKTOP (vana saidi kujundus laiadel ekraanidel) */
  @media (min-width: 768px) {
    .header { padding: 12px 40px; }
    .header__logo img { height: 36px; }

    .hero {
      min-height: 82vh;
      justify-content: flex-start;
    }
    .hero__bg { object-position: 72% center; }
    .hero__content {
      max-width: 940px;
      margin-left: 6vw;
      padding: 48px 24px;
    }
    .hero__title { font-size: 58px; max-width: none; }
    .hero__event { font-size: 32px; max-width: none; }
    .hero__register { font-size: 15px; margin-bottom: 34px; }
    .hero__cta-btn { font-size: 17px; padding: 24px 24px; margin-bottom: 18px; }
    .hero__services { flex-wrap: nowrap; }
    .hero__service-btn { flex: 1; padding: 18px 14px; font-size: 17px; }
    .hero__service-btn--center { flex: 1; }

    .intro, .about, .benefits, .experience, .partners, .testimonials { padding: 64px 40px; }

    .intro__cols {
      max-width: 1200px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1.15fr 1fr;
      gap: 56px;
      align-items: center;
      text-align: left;
    }
    .intro__title { font-size: 30px; text-align: center; margin-bottom: 24px; }
    .intro__text { font-size: 15.5px; }
    .intro__photo { max-width: none; margin: 0; }

    .about__title { font-size: 30px; margin-bottom: 28px; }
    .about__text { font-size: 15.5px; max-width: 1100px; margin-left: auto; margin-right: auto; }

    .benefits {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 16px 48px;
      padding: 32px max(40px, calc((100% - 1150px) / 2)) 64px;
    }
    .benefit__icon { width: 70px; }

    .cta-ribbon { padding: 40px; }
    .cta-ribbon__title { font-size: 26px; }

    .experience__cols {
      max-width: 1200px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1.15fr 1fr;
      gap: 56px;
      align-items: center;
      text-align: left;
    }
    .experience__heading { font-size: 28px; text-align: center; }
    .experience__subheading { font-size: 22px; text-align: center; }
    .experience__text { font-size: 15.5px; }
    .experience__photo { width: 100%; max-width: none; margin: 0; }

    .testimonials__title { font-size: 30px; margin-bottom: 40px; }
    .testimonials__cols {
      max-width: 1150px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 72px;
      align-items: start;
    }
    .testimonial__text { font-size: 18px; }

    .partners__grid {
      flex-direction: row;
      flex-wrap: wrap;
      justify-content: center;
      gap: 48px;
    }
    .partners__grid img { max-width: 230px; }
  }
</style>

<script>
  // Hero "Järgmine grupihingamine" uueneb automaatselt broneerimissüsteemi seansside järgi.
  // Kui API ei vasta või seansse pole, jääb HTML-i staatiline tekst (varutekst).
  (async () => {
    try {
      const res = await fetch('/api/booking/availability?type=group');
      if (!res.ok) return;
      const data = await res.json();
      const next = (data.sessions || [])[0];
      if (!next) return;
      const [y, m, d] = next.date.split('-');
      const el = document.getElementById('hero-event');
      if (el) el.textContent = `The next group breathing session will take place on ${d}.${m} at ${next.time}`;
    } catch {}
  })();
</script>
