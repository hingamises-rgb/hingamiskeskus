---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import RelatedLinks from '../../components/RelatedLinks.astro';
---

<Layout
  title="Hingamiskeskus membership – become a member and enjoy benefits"
  description="Hingamiskeskus membership: floating and group breathing sessions for members at €30, gift cards 15% off and much more. Become a member and enjoy the benefits!"
  keywords="Hingamiskeskus membership"
  lang="en"
  alternates={{ et: '/hakka-liikmeks', ru: '/ru/chlenstvo', en: '/en/membership' }}
>

<Header active="liikmeks" lang="en" />

<section class="membership">
  <div class="membership__layout">
    <div class="membership__content">
      <h1>Hingamiskeskus membership</h1>

      <h2>What does membership include?</h2>
      <p>The monthly membership fee is <strong>€59</strong>, which includes <strong>two sessions per month</strong>: one <a href="/en/floating">floating session</a> and one <a href="/en/breathwork">group breathing session</a> <strong>(regular price €80 in total)</strong>.</p>

      <p>In addition:</p>
      <ul class="membership__benefits">
        <li>Unlimited floating sessions at €30 each</li>
        <li>Unlimited group breathing sessions at €30 each</li>
        <li><a href="/en/shop">Gift cards</a> at a 15% discount for members</li>
        <li>Unused floating sessions are valid for 1 year</li>
        <li>Bring a friend for €30</li>
        <li>3-month commitment, 1-month notice period</li>
        <li>Option to temporarily suspend membership (up to 3 months per year)</li>
      </ul>
    </div>

    <div class="membership__side">
      <img src="/images/dscf6099.jpg" alt="Floating at Hingamiskeskus" class="membership__image" />
      <a href="https://buy.stripe.com/4gweXtfnR98Da523cc" class="membership__btn" id="hakka-btn" target="_blank" rel="noopener">BECOME A MEMBER</a>
    </div>
  </div>

  <div class="membership__terms">
    <h2>Terms</h2>
    <ul>
      <li>Membership is <strong>personal</strong> and cannot be transferred without the permission of Hingamiskeskus.</li>
      <li>Unused floating sessions are valid for 1 <strong>year</strong> but are not refunded in cash.</li>
      <li>Hingamiskeskus has the right to change prices, giving timely notice.</li>
      <li>If the center has to close for renovations for up to <strong>7 days</strong>, this does not affect the membership fee. In case of a longer closure, members are offered the option of immediate cancellation of membership.</li>
      <li>Membership can be suspended for up to <strong>3 months per year</strong> by giving written notice (<a href="mailto:info@hingamiskeskus.ee">info@hingamiskeskus.ee</a>).</li>
      <li>Valid indefinitely, notice period <strong>1 calendar month</strong>.</li>
    </ul>
  </div>
</section>

<RelatedLinks lang="en" links={[
  { href: "/en/floating", label: "Floating", desc: "Deep relaxation in Epsom salt water" },
  { href: "/en/breathwork", label: "Breathwork", desc: "Guided breathing session in a group" },
  { href: "/en/book-a-session", label: "Book a Session", desc: "Choose a suitable time from the calendar" },
]} />

<Footer lang="en" />

</Layout>

<style>
  .header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 10px 16px; background: #fff; position: sticky; top: 0; z-index: 100;
    border-bottom: 1px solid rgba(0,0,0,0.05);
  }
  .header__logo img { height: 28px; width: auto; }
  .header__nav {
    display: none;
    gap: 24px;
  }
  .header__nav a {
    font-size: 14px;
    color: #1d1e20;
    text-decoration: none;
    font-weight: 500;
  }
  .header__nav a.active {
    text-decoration: underline;
    text-underline-offset: 4px;
  }
  .header__right { display: flex; align-items: center; gap: 16px; }
  .header__cart { color: #1d1e20; }
  .header__burger { display: flex; flex-direction: column; gap: 5px; padding: 4px; background: none; border: none; cursor: pointer; }
  .header__burger span { display: block; width: 22px; height: 2px; background: #1d1e20; }

  @media (min-width: 768px) {
    .header__nav { display: flex; }
    .header__burger { display: none; }
  }

  .membership {
    background: #f3fcff;
    padding: 40px max(24px, calc((100% - 1150px) / 2)) 56px;
  }

  .membership__layout {
    display: flex;
    flex-direction: column;
    gap: 40px;
  }

  @media (min-width: 768px) {
    .membership__layout {
      flex-direction: row;
      gap: 64px;
    }
    .membership__content { flex: 3; }
    .membership__side { flex: 2; position: sticky; top: 100px; align-self: flex-start; }
    .membership h1, .membership h2 { text-align: left; }
  .membership h1 { font-size: 48px; margin-bottom: 40px; }
    .membership p, .membership li, .membership__benefits li { font-size: 18px; }
  }

  .membership h1, .membership h2 { text-align: left; }
  .membership h1 {
    font-family: 'DM Sans', sans-serif;
    font-size: 32px;
    font-weight: 700;
    margin-bottom: 32px;
    color: #1d1e20;
  }

  .membership h2 {
    font-size: 18px;
    font-weight: 700;
    margin-top: 28px;
    margin-bottom: 12px;
    color: #1d1e20;
  }

  .membership p {
    font-size: 18px;
    line-height: 1.7;
    color: #333;
    margin-bottom: 12px;
  }

  .membership ul {
    list-style: disc;
    padding-left: 20px;
    margin-bottom: 16px;
    text-align: left;
  }

  .membership li {
    font-size: 15px;
    line-height: 1.7;
    color: #333;
    margin-bottom: 6px;
  }

  .membership a {
    color: #1f6d85;
  }

  .membership__btn {
    display: block;
    background: #0d0d0d;
    color: #fff !important;
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    text-align: center;
    padding: 22px 32px;
    border-radius: 10px;
    margin-top: 32px;
  }
  .membership__btn:hover { opacity: 0.88; }

  .membership__benefits {
    list-style: disc;
    padding-left: 20px;
    margin-bottom: 16px;
    text-align: left;
  }
  .membership__benefits li {
    font-size: 15px;
    line-height: 1.7;
    color: #333;
    margin-bottom: 6px;
  }

  .membership__terms {
    background: #f3fcff;
    padding: 0 max(24px, calc((100% - 1150px) / 2)) 56px;
  }

  .membership__terms h2 { text-align: left; }
  .membership__terms h2 {
    font-size: 18px;
    font-weight: 700;
    margin-bottom: 12px;
    color: #1d1e20;
  }

  .membership__terms ul {
    list-style: disc;
    padding-left: 20px;
    margin-bottom: 16px;
  }

  .membership__terms li {
    font-size: 15px;
    line-height: 1.7;
    color: #333;
    margin-bottom: 6px;
  }

  .membership__terms a {
    color: #1f6d85;
  }

  .membership__image {
    width: 100%;
    border-radius: 10px;
    object-fit: cover;
    max-height: 500px;
  }

  .membership__btn {
    display: block;
    text-align: center;
    background: #1d1e20;
    color: #fff;
    font-size: 12px;
    letter-spacing: 1.5px;
    padding: 16px 32px;
    border-radius: 10px;
    text-decoration: none;
    margin-top: 28px;
    font-family: 'DM Sans', sans-serif;
    font-weight: 700;
  }

  .location {
    background: #1f6d85;
    padding: 20px 24px 24px;
    color: #fff;
    text-align: center;
  }
  .location__title {
    font-size: 18px;
    font-weight: 500;
    margin-bottom: 4px;
  }
  .location__address {
    font-size: 14px;
  }
  .location__photo {
    width: 80%;
    max-width: 320px;
    margin: 12px auto 0;
    display: block;
    border-radius: 10px;
  }
  .footer__main {
    background: #1f6d85;
    padding: 24px;
    color: #fff;
  }
  .footer__logo {
    height: 30px;
    width: auto;
    margin: 0 auto 20px;
    display: block;
  }
  .footer__contact h3,
  .footer__hours h3 {
    font-size: 16px;
    font-weight: 500;
    margin-bottom: 8px;
  }
  .footer__contact p,
  .footer__hours p {
    font-size: 18px;
    line-height: 1.8;
  }
  .footer__hours {
    margin-top: 16px;
  }
  .footer__social {
    display: flex;
    gap: 16px;
    margin-top: 16px;
    color: #fff;
  }
  .footer__legal {
    font-size: 11px;
    margin-top: 16px;
    opacity: 0.7;
    border-top: 1px solid rgba(255,255,255,0.2);
    padding-top: 12px;
  }
  .footer__legal a { color: #fff; text-decoration: none; }
  .footer__legal a:hover { text-decoration: underline; }
</style>
