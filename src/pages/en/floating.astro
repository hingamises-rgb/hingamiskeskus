---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import RelatedLinks from '../../components/RelatedLinks.astro';

// FAQPage schema — hoia sünkroonis lehe FAQ-plokiga!
const FAQ = [
  ['Is floating in Tallinn suitable for a first-time experience?', 'Yes. Most of our visitors come to floating for the first time, and before the session the therapist calmly explains the whole process.'],
  ['How much does floating in Tallinn cost?', 'A single floating session costs 40 € and lasts 1 hour. The 3-session trial package costs 75 €.'],
  ['Where is floating in Tallinn located?', 'Hingamiskeskus is located at Sõle 14c in Tallinn, near the city center. Convenient parking is available in front of the building.'],
  ['Is floating suitable for pregnant women?', 'Yes. Floating helps reduce pressure on the back and legs and offers the body deep relaxation. We recommend contacting us before booking.'],
  ['Do you need to know how to swim to float?', 'No. The Epsom salt concentration in the water is so high that the body naturally stays on the surface.'],
];
const FAQ_SCHEMA = {
  '@type': 'FAQPage',
  mainEntity: FAQ.map(([q, a]) => ({ '@type': 'Question', name: q, acceptedAnswer: { '@type': 'Answer', text: a } })),
};
---

<Layout
  title="Floating Tallinn – Release Muscle Tension | Hingamiskeskus"
  description="Floating Tallinn at Hingamiskeskus helps relax the body, improve sleep and speed up recovery. Float in Epsom salt water to relieve stress, tension and muscle pain!"
  keywords="Floating lõõgastustehnika, Floating magneesiumsoolavannis, Floating Tallinn"
  lang="en"
  alternates={{ et: '/floating', ru: '/ru/floating', en: '/en/floating' }}
  schema={FAQ_SCHEMA}
>

<!-- HEADER -->
<Header active="teenused" lang="en" />

<!-- HERO SECTION (vana lehe paigutus: tekst + punktid vasakul, püstine video + nupud paremal) -->
<section class="float-hero">
  <div class="float-hero__content">
