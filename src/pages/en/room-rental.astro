---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import ContactForm from '../../components/ContactForm.astro';
import Footer from '../../components/Footer.astro';
---

<Layout
  title="Room Rental in Tallinn | Hingamiskeskus"
  description="Rent a cozy room rental in Tallinn at Hingamiskeskus. 38m² hall for workshops and a private 11m² room for individual sessions. Contact us to book your space today!"
  keywords="room rental Tallinn, room rental in Tallinn"
  lang="en"
  alternates={{ et: '/ruumide-rent', ru: '/ru/arenda-pomeshenij', en: '/en/room-rental' }}
>

<!-- HEADER -->
<Header active="teenused" lang="en" />

<!-- HERO SECTION -->
<section class="float-hero">
  <div class="float-hero__content">
    <div class="float-hero__text">
      <h1 class="float-hero__title">Room rental</h1>
      <p>At Hingamiskeskus, we offer cozy and harmonious spaces designed to support deep relaxation, inner peace, and connection with yourself. The atmosphere of our center is ideal for various mindfulness and personal development practices.</p>
      <p>Room rentals are available by agreement. If you wish to rent a space, please fill out the contact form below, specifying your needs and preferred dates. We prioritize long-term clients who wish to use the rooms regularly.</p>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="float-info float-info--cta">
  <a href="#kontaktivorm" class="float-cta__btn">FILL THE FORM</a>
</section>

<!-- ROOMS -->
<section class="float-info">
  <h2 class="float-info__heading">Large hall 38m²</h2>
  <p>Our 38 m² hall is ideal for various events, offering spaciousness and comfort. The room is equipped with blankets, pillows, and mattresses, creating a cozy and relaxing environment for both seated and lying-down activities. This makes it perfect for workshops, trainings, and group meetings where comfort and relaxation are key.</p>
  <p><strong>Price: €25/hour + VAT.</strong></p>

  <div class="room-gallery">
    <img src="/images/ruum-suur-1.jpg" alt="Hingamiskeskus large hall with screen and curtains" class="room-gallery__img" loading="lazy"  width="768" height="432" />
    <img src="/images/ruum-suur-2.jpg" alt="Large hall with mattresses for group work" class="room-gallery__img" loading="lazy"  width="768" height="432" />
    <img src="/images/ruum-suur-3.jpg" alt="Large hall with the Hingamiskeskus logo wall" class="room-gallery__img" loading="lazy"  width="768" height="432" />
    <img src="/images/ruum-suur-4.jpg" alt="Large hall with curtains and pillow shelf" class="room-gallery__img" loading="lazy"  width="768" height="432" />
    <img src="/images/ruum-suur-5.jpg" alt="Large hall with mattresses and blanket shelf" class="room-gallery__img" loading="lazy"  width="768" height="432" />
    <img src="/images/ruum-suur-6.jpg" alt="Large hall with logo wall and Japanese screen" class="room-gallery__img" loading="lazy"  width="768" height="432" />
  </div>

  <h2 class="float-info__heading float-info__heading--spaced">Small room 11m²</h2>
  <p>Our 11 m² room is a cozy and private space, ideal for individual sessions or small meetings. The room is furnished with a small bed, two chairs, a table, and shelves. Soft lighting creates a warm and pleasant atmosphere, supporting focus and a sense of calm.</p>
  <p><strong>Price: €7/hour + VAT.</strong></p>

  <div class="room-gallery">
    <img src="/images/ruum-vaike-1.jpg" alt="Small room with bed, armchair and tea tray" class="room-gallery__img" loading="lazy"  width="768" height="432" />
    <img src="/images/ruum-vaike-2.jpg" alt="Small room with armchair and shelf" class="room-gallery__img" loading="lazy"  width="768" height="426" />
    <img src="/images/ruum-vaike-3.jpg" alt="Small room with two armchairs and mandala art" class="room-gallery__img" loading="lazy"  width="768" height="432" />
    <img src="/images/ruum-vaike-4.jpg" alt="Small room with armchair and shelving" class="room-gallery__img" loading="lazy"  width="768" height="1364" />
  </div>

  <p style="margin-top: 24px;">To book a session, leave us your contact details and we will get in touch with you: <a href="mailto:Info@hingamiskeskus.ee" class="float-info__link">Info@hingamiskeskus.ee</a></p>
</section>

<!-- KONTAKTIVORM -->
<ContactForm source="Ruumide rent (EN)" lang="en" title="Room rental inquiry" description="Describe your needs and preferred dates and we will get in touch with you" />

<Footer lang="en" />

</Layout>

<style>
  /* HEADER */
  .header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 16px;
    background: #fff;
    position: sticky;
    top: 0;
    z-index: 100;
    border-bottom: 1px solid rgba(0,0,0,0.05);
  }
  .header__logo img { height: 28px; width: auto; }
  .header__right { display: flex; align-items: center; gap: 16px; }
  .header__cart { color: #1d1e20; }
  .header__burger {
    display: flex;
    flex-direction: column;
    gap: 5px;
    padding: 4px;
  }
  .header__burger span {
    display: block;
    width: 22px;
    height: 2px;
    background: #1d1e20;
  }

  /* HERO */
  .float-hero {
    background: #f3fcff;
    padding: 32px 24px;
  }
  .float-hero__content {
    max-width: 1100px;
    margin: 0 auto;
  }
  .float-hero__title {
    font-size: 28px;
    font-weight: 700;
    line-height: 1.3;
    margin-bottom: 12px;
    color: #1d1e20;
  }
  .float-hero__text p {
    font-size: 18px;
    line-height: 1.7;
    color: #1d1e20;
    margin-bottom: 12px;
  }
  .float-hero__img {
    width: 100%;
    border-radius: 10px;
    margin-top: 24px;
  }

  /* CTA */
  .float-info--cta {
    text-align: center;
  }
  .float-cta__btn {
    display: inline-block;
    background: #1d1e20;
    color: #fff;
    font-size: 12px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    padding: 14px 32px;
    border-radius: 10px;
  }

  /* INFO / CONTENT */
  .float-info {
    background: #f3fcff;
    padding: 32px 24px;
    max-width: 800px;
    margin: 0 auto;
  }
  .float-info p {
    font-size: 18px;
    line-height: 1.7;
    color: #1d1e20;
    margin-bottom: 16px;
  }
  .float-info p:last-child {
    margin-bottom: 0;
  }
  .float-info__heading {
    font-size: 20px;
    font-weight: 700;
    margin-bottom: 16px;
    color: #1d1e20;
  }
  .float-info__heading--spaced {
    margin-top: 32px;
  }
  .float-info__link {
    color: #1f6d85;
    text-decoration: underline;
  }

  /* ROOM GALLERY */
  .room-gallery {
    display: grid;
    grid-template-columns: 1fr;
    gap: 12px;
    margin-top: 16px;
    margin-bottom: 8px;
  }
  .room-gallery__img {
    width: 100%;
    border-radius: 10px;
    clip-path: inset(0 round 10px);
  }

  /* LOCATION */
  .location {
    background: #1f6d85;
    padding: 20px 24px 24px;
    color: #fff;
    text-align: center;
  }
  .location__title {
    font-size: 18px;
    font-weight: 500;
    margin-bottom: 4px;
  }
  .location__address {
    font-size: 14px;
  }
  .location__photo {
    width: 80%;
    max-width: 320px;
    margin: 12px auto 0;
    display: block;
    border-radius: 10px;
  }

  /* FOOTER */
  .footer__main {
    background: #1f6d85;
    padding: 24px;
    color: #fff;
  }
  .footer__logo {
    height: 30px;
    width: auto;
    margin: 0 auto 20px;
    display: block;
  }
  .footer__contact h3, .footer__hours h3 {
    font-size: 16px;
    font-weight: 500;
    margin-bottom: 8px;
  }
  .footer__contact p, .footer__hours p {
    font-size: 18px;
    line-height: 1.8;
  }
  .footer__hours {
    margin-top: 16px;
  }
  .footer__social {
    display: flex;
    gap: 16px;
    margin-top: 16px;
    color: #fff;
  }
  .footer__social a { color: #fff; }
  .footer__legal {
    font-size: 11px;
    margin-top: 16px;
    opacity: 0.7;
    border-top: 1px solid rgba(255,255,255,0.2);
    padding-top: 12px;
  }
  .footer__legal a { color: #fff; text-decoration: none; }

  /* DESKTOP */
  @media (min-width: 768px) {
    .header { padding: 12px 40px; }
    .header__logo img { height: 36px; }

    .float-hero { padding: 48px 40px; }
    .float-hero__content {
      display: flex;
      align-items: center;
      gap: 40px;
    }
    .float-hero__text {
      flex: 1;
    }
    .float-hero__media {
      flex: 1;
    }
    .float-hero__title { font-size: 36px; }
    .float-hero__img { margin-top: 0; }

    .float-info { padding: 40px; }
    .room-gallery { grid-template-columns: 1fr 1fr; }
  }

  @media (min-width: 1024px) {
    .float-hero__title { font-size: 40px; }
    .float-hero { padding: 56px 40px; }
  }
</style>
