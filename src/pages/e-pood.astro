---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import { requireDb } from '../lib/db';

// Tooted loetakse build'i ajal andmebaasist — admin paneelis tehtud
// muudatused jõustuvad e-poes järgmise deploy'ga.
const sql = requireDb();
const allProducts = await sql`
  SELECT slug, page_slug, title, alt, image, cart_name, price, old_price, price_prefix, category, sold_out
  FROM products WHERE active = true ORDER BY sort, slug
`;

const CATEGORIES = [
  { id: 'kinkekaardid', title: 'Kinkekaardid' },
  { id: 'paketid', title: 'Paketid' },
  { id: 'vitamiinid', title: 'Vitamiinid' },
  { id: 'epsomi-sool', title: 'Epsomi sool' },
];

const byCategory = new Map(CATEGORIES.map(c => [c.id, []]));
for (const p of allProducts) {
  if (byCategory.has(p.category)) byCategory.get(p.category).push(p);
}

function fmtPrice(v: unknown) {
  return `€${Number(v).toFixed(2)}`;
}

// Ostukorvi jaoks: slug -> { name, price }
const PRODUCTS_DATA: Record<string, { name: string; price: number }> = {};
for (const p of allProducts) {
  if (!p.sold_out) PRODUCTS_DATA[p.slug] = { name: p.cart_name, price: Number(p.price) };
}
---

<Layout
  title="Hingamiskeskuse e-pood Epsomi sool, vitamiinid ja paketid"
  description="Hingamiskeskuse e-pood Epsomi soola (rahvakeeli Epsom sool), vitamiinide ja lõõgastuspakettide jaoks. Alusta taskukohase proovipaketiga! Pakume kinkekaarte, kvaliteetseid tooteid keha taastumiseks ja stressist vabanemiseks. Erinevad pakendisuurused. Telli kohe!"
  keywords="Epsomi sool, paketid, Hingamiskeskuse e-pood"
>

<!-- HEADER -->
<Header active="epood" />

<!-- PAGE TITLE -->
<section class="page-hero">
  <h1 class="page-hero__title">E-pood</h1>
</section>

<!-- CATEGORY NAV -->
<nav class="cat-nav">
  <a href="#kinkekaardid" class="cat-nav__btn">KINKEKAARDID</a>
  <a href="#paketid" class="cat-nav__btn">PAKETID</a>
  <a href="#vitamiinid" class="cat-nav__btn">VITAMIINID</a>
  <a href="#epsomi-sool" class="cat-nav__btn">EPSOMI SOOL</a>
</nav>

<!-- INTRO TEXT -->
<section class="shop-intro">
  <h2 class="shop-intro__heading">Hingamiskeskuse e-pood</h2>
  <p>Hingamiskeskuse e-poest leiad kõik, mis toetab sinu heaolu ja lõõgastust nii kodus kui ka meie keskuses.</p>

  <h3 class="shop-intro__subheading">Kinkekaardid ja paketid</h3>
  <p>Kõiki meie kinkekaarte ja pakette saab kasutada paindlikult nii floatingu seanssideks kui ka vabastava hingamise seanssideks. Iga kord saad ise valida, millist kogemust parasjagu vajad. Korrakaarte saab kasutada ka leibkonna siseselt, mis tähendab, et ühe kaardiga saavad seansse broneerida ka teised pereliikmed.</p>
  <p><strong>Kinkekaardid</strong> on suurepärane kingitus lähedastele. Saadame kaardi e-mailile või soovi korral saad tulla füüsilisele kaardile ise järele. Kaardid kehtivad 6 kuud.</p>

  <h3 class="shop-intro__subheading">Epsomi sool</h3>
  <p>Meie e-poes on viis erinevat Epsomi soola: puhas sool ning eeterlike õlidega variandid, mis muudavad koduvanni eriti lõõgastavaks ja meeldivalt lõhnavaks. Epsomi sool sisaldab magneesiumi, mis aitab lõdvestada lihaseid, rahustab närvisüsteemi ja toetab paremat und. Ideaalne valik igapäevaseks taastumiseks ja lõõgastumiseks ka kodus.</p>
</section>

<!-- TOOTED (andmebaasist, kategooriate kaupa) -->
{CATEGORIES.map(cat => (
  <section class="product-section" id={cat.id}>
    <h2 class="product-section__title">{cat.title}</h2>
    <div class="product-grid">
      {byCategory.get(cat.id).map(p => (
        p.sold_out ? (
          <div class="product-card product-card--sold-out">
            <div class="product-card__ribbon">SOLD OUT</div>
            <a href={p.page_slug ? `/${p.page_slug}` : '/e-pood'} class="product-card__link">
              <img src={p.image} alt={p.alt} class="product-card__img" loading="lazy" />
              <h3 class="product-card__title">{p.title}</h3>
            </a>
            <p class="product-card__price product-card__price--sold-out">Sold out</p>
          </div>
        ) : (
          <div class="product-card">
            <a href={p.page_slug ? `/${p.page_slug}` : '/e-pood'} class="product-card__link">
              <img src={p.image} alt={p.alt} class="product-card__img" loading="lazy" />
              <h3 class="product-card__title">{p.title}</h3>
            </a>
            <p class="product-card__price">{p.price_prefix ? p.price_prefix + ' ' : ''}{p.old_price && <><span class="price--old">{fmtPrice(p.old_price)}</span>{' '}</>}{fmtPrice(p.price)}</p>
            <button class="product-card__btn" data-product={p.slug}>LISA OSTUKORVI</button>
          </div>
        )
      ))}
    </div>
  </section>
))}

<!-- FOOTER -->
<footer class="footer">
  <div class="location">
    <h3 class="location__title">Aadress</h3>
    <p class="location__address">Söle 14c, Tallinn</p>
    <img src="/images/hoone.jpg" alt="Hingamiskeskus Söle 14c" class="location__photo" loading="lazy" />
  </div>
  <div class="footer__main">
    <img src="/images/logo-valge.png" alt="Hingamiskeskus" class="footer__logo" />
    <div class="footer__contact">
      <h3>Kontakt</h3>
      <p>E-post: Info@hingamiskeskus.ee</p>
      <p>Telefoninumber:</p>
      <p>+372 56695898</p>
      <p>+372 56497689</p>
      <p>(klienditugi 10.00-17.00)</p>
      <p>Hingamises OÜ</p>
      <p>EE147700771009732310</p>
    </div>
    <div class="footer__hours">
      <h3>Lahtiolekuajad</h3>
      <p>E-R 8.30 - 20.00</p>
      <p>L-P 11.00 - 18.00</p>
    </div>
    <div class="footer__social">
      <a href="https://www.facebook.com/Hingamiskeskus" aria-label="Facebook" target="_blank" rel="noopener">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
      </a>
      <a href="https://www.instagram.com/hingamiskeskus/" aria-label="Instagram" target="_blank" rel="noopener">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="5"/><circle cx="17.5" cy="6.5" r="1.5" fill="currentColor" stroke="none"/></svg>
      </a>
    </div>
    <div class="footer__legal">
      <a href="/privaatsuspoliitika">Privaatsuspoliitika</a> | <a href="/muugitingimused">Müügitingimused</a>
    </div>
  </div>
</footer>

</Layout>

<script is:inline define:vars={{ PRODUCTS_DATA }}>
  const PRODUCTS = PRODUCTS_DATA;

  function getCart() {
    try { return JSON.parse(localStorage.getItem('hk_cart') || '[]'); }
    catch { return []; }
  }

  function saveCart(cart) {
    localStorage.setItem('hk_cart', JSON.stringify(cart));
    updateBadge();
  }

  function updateBadge() {
    const cart = getCart();
    const count = cart.reduce(function(s, i) { return s + i.qty; }, 0);
    let badge = document.querySelector('.cart-badge');
    if (count > 0) {
      if (!badge) {
        badge = document.createElement('span');
        badge.className = 'cart-badge';
        document.querySelector('.header__cart').appendChild(badge);
      }
      badge.textContent = count;
    } else if (badge) {
      badge.remove();
    }
  }

  function addToCart(productId) {
    const product = PRODUCTS[productId];
    if (!product) return;
    const cart = getCart();
    const existing = cart.find(function(item) { return item.id === productId; });
    if (existing) {
      existing.qty += 1;
    } else {
      cart.push({ id: productId, name: product.name, price: product.price, qty: 1 });
    }
    saveCart(cart);
  }

  document.querySelectorAll('.product-card__btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var productId = this.getAttribute('data-product');
      addToCart(productId);
      this.textContent = 'LISATUD ✓';
      var self = this;
      setTimeout(function() { self.textContent = 'LISA OSTUKORVI'; }, 1500);
    });
  });

  updateBadge();
</script>

<style>
  /* HEADER */
  .header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 16px;
    background: #fff;
    position: sticky;
    top: 0;
    z-index: 100;
    border-bottom: 1px solid rgba(0,0,0,0.05);
  }
  .header__logo img { height: 28px; width: auto; }
  .header__right { display: flex; align-items: center; gap: 16px; }
  .header__cart { color: #1d1e20; position: relative; }
  :global(.cart-badge) {
    position: absolute;
    top: -6px;
    right: -8px;
    background: #1f6d85;
    color: #fff;
    font-size: 10px;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
  }
  .header__burger {
    display: flex;
    flex-direction: column;
    gap: 5px;
    padding: 4px;
  }
  .header__burger span {
    display: block;
    width: 22px;
    height: 2px;
    background: #1d1e20;
  }

  /* PAGE HERO */
  .page-hero {
    background: #f3fcff;
    padding: 40px 24px;
    text-align: center;
  }
  .page-hero__title {
    font-size: 32px;
    font-weight: 400;
  }

  /* CATEGORY NAV */
  .cat-nav {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 24px 16px;
    background: #fff;
  }
  .cat-nav__btn {
    display: block;
    background: #1d1e20;
    color: #fff;
    font-size: 14px;
    letter-spacing: 1.5px;
    padding: 16px 20px;
    border-radius: 10px;
    text-align: center;
    outline: none;
    -webkit-tap-highlight-color: transparent;
  }

  /* SHOP INTRO */
  .shop-intro {
    padding: 0 24px 32px;
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
  }
  .shop-intro__heading {
    font-size: 20px;
    font-weight: 700;
    margin-bottom: 8px;
  }
  .shop-intro__subheading {
    font-size: 18px;
    font-weight: 700;
    margin-top: 20px;
    margin-bottom: 6px;
  }
  .shop-intro p {
    font-size: 14px;
    color: #333;
    line-height: 1.7;
    margin-bottom: 8px;
  }

  /* PRODUCT SECTION */
  .product-section {
    padding: 32px 16px;
    scroll-margin-top: 60px;
  }
  .product-section:nth-child(even) {
    background: #f3fcff;
  }
  .product-section__title {
    text-align: center;
    font-size: 28px;
    font-weight: 400;
    margin-bottom: 24px;
    color: #1d1e20;
  }

  /* PRODUCT GRID */
  .product-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
    max-width: 1200px;
    margin: 0 auto;
  }

  /* PRODUCT CARD */
  .product-card {
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .product-card__ribbon {
    position: absolute;
    top: 12px;
    left: 12px;
    background: #1d1e20;
    color: #fff;
    font-size: 11px;
    letter-spacing: 1px;
    padding: 6px 12px;
    border-radius: 4px;
    z-index: 2;
  }
  .product-card__img {
    width: 100%;
    display: block;
    border-radius: 0;
    clip-path: inset(0 round 10px);
  }
  #paketid .product-card__img {
    aspect-ratio: 768/431;
    object-fit: cover;
  }
  .product-card--sold-out .product-card__img {
    opacity: 0.6;
  }
  .product-card__title {
    font-size: 16px;
    font-weight: 400;
    padding: 12px 8px 4px;
    line-height: 1.4;
  }
  .product-card__price {
    font-size: 16px;
    color: #1d1e20;
    padding: 4px 0 12px;
  }
  .product-card__price--sold-out {
    color: #999;
    font-style: italic;
  }
  .price--old {
    text-decoration: line-through;
    color: #999;
    margin-right: 4px;
  }
  .product-card__btn {
    display: inline-block;
    background: #1d1e20;
    color: #fff;
    font-size: 12px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    padding: 12px 28px;
    border-radius: 10px;
    border: none;
    cursor: pointer;
    font-family: 'DM Sans', sans-serif;
  }
  .product-card__btn:hover {
    background: #333;
  }

  /* LOCATION */
  .location {
    background: #1f6d85;
    padding: 20px 24px 24px;
    color: #fff;
    text-align: center;
  }
  .location__title {
    font-size: 18px;
    font-weight: 500;
    margin-bottom: 4px;
  }
  .location__address {
    font-size: 14px;
  }
  .location__photo {
    width: 80%;
    max-width: 320px;
    margin: 12px auto 0;
    display: block;
    border-radius: 10px;
  }

  /* FOOTER */
  .footer__main {
    background: #1f6d85;
    padding: 24px;
    color: #fff;
  }
  .footer__logo {
    height: 30px;
    width: auto;
    margin: 0 auto 20px;
    display: block;
  }
  .footer__contact h3,
  .footer__hours h3 {
    font-size: 16px;
    font-weight: 500;
    margin-bottom: 8px;
  }
  .footer__contact p,
  .footer__hours p {
    font-size: 13px;
    line-height: 1.8;
  }
  .footer__hours {
    margin-top: 16px;
  }
  .footer__social {
    display: flex;
    gap: 16px;
    margin-top: 16px;
    color: #fff;
  }
  .footer__legal {
    font-size: 11px;
    margin-top: 16px;
    opacity: 0.7;
    border-top: 1px solid rgba(255,255,255,0.2);
    padding-top: 12px;
  }
  .footer__legal a:hover { text-decoration: underline; }

  /* DESKTOP */
  @media (min-width: 768px) {
    .header { padding: 12px 40px; }
    .header__logo img { height: 36px; }
    .page-hero { padding: 60px 40px; }
    .page-hero__title { font-size: 42px; }
    .cat-nav { flex-direction: row; flex-wrap: wrap; justify-content: center; padding: 32px 40px; gap: 16px; }
    .cat-nav__btn { display: inline-block; width: auto; font-size: 13px; padding: 14px 28px; }
    .shop-intro { padding: 0 40px 40px; }
    .product-section { padding: 40px; }
    .product-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
    }
    .product-card__title { font-size: 18px; }
  }
</style>
