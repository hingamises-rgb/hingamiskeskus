<style>
  /* HEADER */
  .header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 16px;
    background: #fff;
    position: sticky;
    top: 0;
    z-index: 100;
    border-bottom: 1px solid rgba(0,0,0,0.05);
  }
  .header__logo img { height: 28px; width: auto; }
  .header__right { display: flex; align-items: center; gap: 16px; }
  .header__cart { color: #1d1e20; }
  .header__burger {
    display: flex;
    flex-direction: column;
    gap: 5px;
    padding: 4px;
  }
  .header__burger span {
    display: block;
    width: 22px;
    height: 2px;
    background: #1d1e20;
  }

  /* PAGE HERO */
  .page-hero {
    background: #f3fcff;
    padding: 40px 24px;
    text-align: center;
  }
  .page-hero__title {
    font-size: 32px;
    font-weight: 400;
  }

  /* CATEGORY NAV */
  .cat-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    justify-content: center;
    padding: 24px 16px;
    background: #fff;
  }
  .cat-nav__btn {
    display: inline-block;
    background: #1d1e20;
    color: #fff;
    font-size: 12px;
    letter-spacing: 1.5px;
    padding: 12px 20px;
    border-radius: 10px;
  }

  /* SHOP INTRO */
  .shop-intro {
    padding: 0 24px 32px;
    max-width: 800px;
    margin: 0 auto;
  }
  .shop-intro__heading {
    font-size: 20px;
    font-weight: 700;
    margin-bottom: 8px;
  }
  .shop-intro__subheading {
    font-size: 18px;
    font-weight: 700;
    margin-top: 20px;
    margin-bottom: 6px;
  }
  .shop-intro p {
    font-size: 14px;
    color: #333;
    line-height: 1.7;
    margin-bottom: 8px;
  }

  /* PRODUCT SECTION */
  .product-section {
    padding: 32px 16px;
    scroll-margin-top: 60px;
  }
  .product-section:nth-child(even) {
    background: #f3fcff;
  }
  .product-section__title {
    text-align: center;
    font-size: 28px;
    font-weight: 400;
    margin-bottom: 24px;
    color: #1d1e20;
  }

  /* PRODUCT GRID */
  .product-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
    max-width: 1200px;
    margin: 0 auto;
  }

  /* PRODUCT CARD */
  .product-card {
    text-align: center;
    position: relative;
  }
  .product-card__ribbon {
    position: absolute;
    top: 12px;
    left: 12px;
    background: #1d1e20;
    color: #fff;
    font-size: 11px;
    letter-spacing: 1px;
    padding: 6px 12px;
    border-radius: 4px;
    z-index: 2;
  }
  .product-card__img {
    width: 100%;
    border-radius: 10px;
  }
  .product-card--sold-out .product-card__img {
    opacity: 0.6;
  }
  .product-card__title {
    font-size: 16px;
    font-weight: 400;
    padding: 12px 8px 4px;
    line-height: 1.4;
  }
  .product-card__price {
    font-size: 16px;
    color: #1d1e20;
    padding: 4px 0 12px;
  }
  .product-card__price--sold-out {
    color: #999;
    font-style: italic;
  }
  .price--old {
    text-decoration: line-through;
    color: #999;
    margin-right: 4px;
  }
  .product-card__btn {
    display: inline-block;
    background: #1d1e20;
    color: #fff;
    font-size: 12px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    padding: 12px 28px;
    border-radius: 10px;
    cursor: pointer;
    font-family: 'DM Sans', sans-serif;
    border: none;
  }
  .product-card__btn:hover {
    background: #333;
  }

  /* LOCATION */
  .location {
    background: #1f6d85;
    padding: 20px 24px 24px;
    color: #fff;
    text-align: center;
  }
  .location__title {
    font-size: 18px;
    font-weight: 500;
    margin-bottom: 4px;
  }
  .location__address {
    font-size: 14px;
  }
  .location__photo {
    width: 80%;
    max-width: 320px;
    margin: 12px auto 0;
    display: block;
    border-radius: 10px;
  }

  /* FOOTER */
  .footer__main {
    background: #1f6d85;
    padding: 24px;
    color: #fff;
  }
  .footer__logo {
    height: 30px;
    width: auto;
    margin: 0 auto 20px;
    display: block;
  }
  .footer__contact h3,
  .footer__hours h3 {
    font-size: 16px;
    font-weight: 500;
    margin-bottom: 8px;
  }
  .footer__contact p,
  .footer__hours p {
    font-size: 13px;
    line-height: 1.8;
  }
  .footer__hours {
    margin-top: 16px;
  }
  .footer__social {
    display: flex;
    gap: 16px;
    margin-top: 16px;
    color: #fff;
  }
  .footer__legal {
    font-size: 11px;
    margin-top: 16px;
    opacity: 0.7;
    border-top: 1px solid rgba(255,255,255,0.2);
    padding-top: 12px;
  }
  .footer__legal a:hover { text-decoration: underline; }

  /* DESKTOP */
  @media (min-width: 768px) {
    .header { padding: 12px 40px; }
    .header__logo img { height: 36px; }
    .page-hero { padding: 60px 40px; }
    .page-hero__title { font-size: 42px; }
    .cat-nav { padding: 32px 40px; gap: 16px; }
    .cat-nav__btn { font-size: 13px; padding: 14px 28px; }
    .shop-intro { padding: 0 40px 40px; }
    .product-section { padding: 40px; }
    .product-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
    }
    .product-card__title { font-size: 18px; }
  }
</style>
