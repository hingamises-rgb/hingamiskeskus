---
// Ühine päis: desktop nav + mobiilne täisekraani menüü (originaali järgi)
import { RU_BY_ET, EN_BY_ET, ET_BY_RU, ET_BY_EN } from '../lib/i18n';
type Lang = 'et' | 'ru' | 'en';
interface Props {
  active?: string; // avaleht | teenused | broneeri | epood | liikmeks | paketid | blogi | kkk
  lang?: Lang;
  /** Keelevahetaja URL-id (ainult dünaamilised lehed — tooted, blogi). Staatilised arvutatakse i18n-kaardist. */
  alts?: Partial<Record<Lang, string>>;
  /** DEPRECATED (2-keelne aeg): jäetakse tähelepanuta, keelevahetaja arvutatakse kaardist. */
  altHref?: string;
}
const { active = '', lang = 'et', alts = {} } = Astro.props;
const ru = lang === 'ru';
const en = lang === 'en';

const SERVICES = ru
  ? [
      { href: '/ru/osoznannoe-dyhanie', label: 'Осознанное дыхание' },
      { href: '/ru/floating', label: 'Флоатинг' },
      { href: '/ru/neurovizr', label: 'Neurovizr' },
      { href: '/ru/dyhanie-v-vode', label: 'Дыхание в воде' },
      { href: '/ru/aromatouch-uhod-za-telom', label: 'Aromatouch уход за телом' },
      { href: '/ru/arenda-pomeshenij', label: 'Аренда помещений' },
      { href: '/ru/nashi-terapevty', label: 'Наши терапевты' },
    ]
  : en
  ? [
      { href: '/en/breathwork', label: 'Breathwork' },
      { href: '/en/floating', label: 'Floating' },
      { href: '/en/neurovizr', label: 'Neurovizr' },
      { href: '/en/breathwork-in-water', label: 'Breathwork in water' },
      { href: '/en/aromatouch-body-treatment', label: 'AromaTouch body treatment' },
      { href: '/en/room-rental', label: 'Room rental' },
      { href: '/en/our-therapists', label: 'Our therapists' },
    ]
  : [
      { href: '/vabastav-hingamine', label: 'Vabastav hingamine' },
      { href: '/floating', label: 'Floating' },
      { href: '/neurovizr', label: 'Neurovizr' },
      { href: '/soojas-vees-hingamine', label: 'Soojas vees hingamine' },
      { href: '/aromatouch-kehahooldus', label: 'Aromatouch kehahooldus' },
      { href: '/ruumide-rent', label: 'Ruumide rent' },
      { href: '/terapeudid', label: 'Terapeudid' },
    ];

// RU navis on Блог; EN-l blogi ei ole (vanal saidil EN artikleid pole)
const NAV = ru
  ? [
      { href: '/ru', key: 'avaleht', label: 'Главная' },
      { href: '/ru/uslugi', key: 'teenused', label: 'Услуги' },
      { href: '/ru/zabronirovat-vremya', key: 'broneeri', label: 'Забронировать время' },
      { href: '/ru/onlajn-shop', key: 'epood', label: 'Интернет-магазин' },
      { href: '/ru/chlenstvo', key: 'liikmeks', label: 'Членство' },
      { href: '/ru/blog', key: 'blogi', label: 'Блог' },
      { href: '/ru/chavo', key: 'kkk', label: 'ЧаВо' },
    ]
  : en
  ? [
      { href: '/en', key: 'avaleht', label: 'Home' },
      { href: '/en/services', key: 'teenused', label: 'Services' },
      { href: '/en/book-a-session', key: 'broneeri', label: 'Book a Session' },
      { href: '/en/shop', key: 'epood', label: 'Shop' },
      { href: '/en/membership', key: 'liikmeks', label: 'Membership' },
      { href: '/en/faq', key: 'kkk', label: 'FAQ' },
    ]
  : [
      { href: '/', key: 'avaleht', label: 'Avaleht' },
      { href: '/teenused', key: 'teenused', label: 'Teenused' },
      { href: '/broneeri-aeg', key: 'broneeri', label: 'Broneeri aeg' },
      { href: '/e-pood', key: 'epood', label: 'E-pood' },
      { href: '/hakka-liikmeks', key: 'liikmeks', label: 'Hakka liikmeks' },
      { href: '/blogi', key: 'blogi', label: 'Blogi' },
      { href: '/kkk', key: 'kkk', label: 'KKK' },
    ];

const homeHref = ru ? '/ru' : en ? '/en' : '/';
const servicesLabel = ru ? 'Услуги' : en ? 'Services' : 'Teenused';

// Keelevahetaja: näita kahte teist keelt.
const LANG_HOME: Record<Lang, string> = { et: '/', ru: '/ru', en: '/en' };
const LANG_ARIA: Record<Lang, string> = { et: 'Eesti keeles', ru: 'На русском', en: 'In English' };
// Staatilistel lehtedel arvuta URL-id i18n-kaardist praeguse tee järgi.
const rawPath = Astro.url.pathname;
const path = rawPath.length > 1 ? rawPath.replace(/\/$/, '') : rawPath;
const etPath = lang === 'et' ? path : lang === 'ru' ? ET_BY_RU[path] : ET_BY_EN[path];
const autoAlts: Partial<Record<Lang, string>> = etPath
  ? { et: etPath, ru: RU_BY_ET[etPath], en: EN_BY_ET[etPath] }
  : {};
// Dünaamilistel lehtedel (tooted, blogi) võetakse alts propist; see kirjutab automaatse üle.
const effectiveAlts: Partial<Record<Lang, string>> = { ...autoAlts, ...alts };
const LANG_LABEL: Record<Lang, string> = { et: 'EST', ru: 'RUS', en: 'EN' };
// Lipud SVG-na (emoji-lipud ei renderdu Windowsis)
const LANG_FLAG: Record<Lang, string> = {
  et: '<svg viewBox="0 0 60 39" xmlns="http://www.w3.org/2000/svg"><rect width="60" height="13" fill="#0072ce"/><rect y="13" width="60" height="13" fill="#000"/><rect y="26" width="60" height="13" fill="#fff"/></svg>',
  ru: '<svg viewBox="0 0 60 39" xmlns="http://www.w3.org/2000/svg"><rect width="60" height="13" fill="#fff"/><rect y="13" width="60" height="13" fill="#0039a6"/><rect y="26" width="60" height="13" fill="#d52b1e"/></svg>',
  en: '<svg viewBox="0 0 60 30" xmlns="http://www.w3.org/2000/svg"><rect width="60" height="30" fill="#012169"/><path d="M0,0 L60,30 M60,0 L0,30" stroke="#fff" stroke-width="6"/><path d="M0,0 L60,30 M60,0 L0,30" stroke="#C8102E" stroke-width="3"/><path d="M30,0 v30 M0,15 h60" stroke="#fff" stroke-width="10"/><path d="M30,0 v30 M0,15 h60" stroke="#C8102E" stroke-width="6"/></svg>',
};
const otherLangs = (['et', 'ru', 'en'] as Lang[])
  .filter((l) => l !== lang)
  .map((l) => ({ code: l, label: LANG_LABEL[l], flag: LANG_FLAG[l], href: effectiveAlts[l] || LANG_HOME[l], aria: LANG_ARIA[l] }));

const headerClass = ru ? 'header header--ru' : en ? 'header header--en' : 'header';
const cartHref = ru ? '/ru/checkout' : en ? '/en/checkout' : '/checkout';
const cartAria = ru ? 'Корзина' : en ? 'Cart' : 'Ostukorv';
const menuAria = ru ? 'Меню' : en ? 'Menu' : 'Menüü';
---

<header class={headerClass} id="site-header">
  <a href={homeHref} class="header__logo">
    <img src="/images/logo.svg" alt="Hingamiskeskus" height="30" />
  </a>
  <nav class="header__nav">
    {NAV.map(item => (
      <a href={item.href} class={active === item.key ? 'active' : ''}>{item.label}</a>
    ))}
  </nav>
  <div class="header__right">
    <div class="header__langs">
      {otherLangs.map((l) => (
        <a href={l.href} class="header__lang" aria-label={l.aria}>
          <span class="header__flag" set:html={l.flag} />{l.label}
        </a>
      ))}
    </div>
    <a href={cartHref} class="header__cart" aria-label={cartAria}>
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/>
      </svg>
    </a>
    <button class="header__burger" id="burger-btn" aria-label={menuAria} aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<div class="mobile-menu" id="mobile-menu" hidden>
  <nav class="mobile-menu__nav">
    <a href={homeHref} class={active === 'avaleht' ? 'mobile-menu__link mobile-menu__link--active' : 'mobile-menu__link'}>{NAV[0].label}</a>
    <button type="button" class="mobile-menu__link mobile-menu__toggle" id="services-toggle" aria-expanded="false">
      {servicesLabel} <span class="mobile-menu__arrow" id="services-arrow">▾</span>
    </button>
    <div class="mobile-menu__sub" id="services-sub" hidden>
      {SERVICES.map(s => (
        <a href={s.href} class="mobile-menu__sublink">{s.label}</a>
      ))}
    </div>
    {NAV.filter(i => !['avaleht', 'teenused'].includes(i.key)).map(item => (
      <a href={item.href} class={active === item.key ? 'mobile-menu__link mobile-menu__link--active' : 'mobile-menu__link'}>{item.label}</a>
    ))}
    {otherLangs.map((l) => (
      <a href={l.href} class="mobile-menu__link mobile-menu__lang">
        <span class="header__flag header__flag--menu" set:html={l.flag} />{l.label}
      </a>
    ))}
  </nav>
</div>

<script is:inline>
(function() {
  const burger = document.getElementById('burger-btn');
  const menu = document.getElementById('mobile-menu');
  const servicesToggle = document.getElementById('services-toggle');
  const servicesSub = document.getElementById('services-sub');
  const servicesArrow = document.getElementById('services-arrow');

  burger.addEventListener('click', function() {
    const open = menu.hidden;
    menu.hidden = !open;
    burger.classList.toggle('header__burger--open', open);
    burger.setAttribute('aria-expanded', String(open));
    document.body.style.overflow = open ? 'hidden' : '';
  });

  servicesToggle.addEventListener('click', function() {
    const open = servicesSub.hidden;
    servicesSub.hidden = !open;
    servicesArrow.textContent = open ? '▴' : '▾';
    servicesToggle.setAttribute('aria-expanded', String(open));
  });

  // Ostukorvi loendur
  try {
    const cart = JSON.parse(localStorage.getItem('hk_cart') || '[]');
    const count = cart.reduce(function(s, i) { return s + i.qty; }, 0);
    if (count > 0) {
      const badge = document.createElement('span');
      badge.className = 'cart-badge';
      badge.textContent = count;
      document.querySelector('#site-header .header__cart').appendChild(badge);
    }
  } catch (e) {}
})();
</script>

<style>
  .header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 16px;
    background: #fff;
    position: sticky;
    top: 0;
    z-index: 200;
    border-bottom: 1px solid rgba(0,0,0,0.05);
  }
  .header__logo img { height: 28px; width: auto; }
  .header__nav { display: none; gap: 24px; }
  .header__nav a {
    font-size: 14px;
    color: #1d1e20;
    text-decoration: none;
    font-weight: 500;
  }
  .header__nav a.active {
    text-decoration: underline;
    text-underline-offset: 4px;
  }
  .header__right { display: flex; align-items: center; gap: 16px; }
  .header__langs { display: flex; align-items: center; gap: 6px; }
  .header__lang {
    display: flex;
    align-items: center;
    gap: 5px;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.5px;
    color: #1d1e20;
    padding: 3px 4px;
  }
  .header__lang:hover { color: #1f6d85; }
  .header__flag :global(svg) {
    display: block;
    width: 20px;
    height: 13px;
    border-radius: 2px;
    box-shadow: 0 0 0 1px rgba(0,0,0,0.15);
  }
  .header__flag--menu :global(svg) { width: 24px; height: 16px; }
  :global(.mobile-menu__lang) {
    margin-top: 18px;
    font-size: 16px !important;
    color: #1f6d85 !important;
    display: flex !important;
    align-items: center;
    gap: 8px;
  }
  .header__cart { color: #1d1e20; position: relative; display: flex; }
  .header__burger {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    padding: 4px;
    width: 30px;
    height: 30px;
    background: none;
    border: none;
    cursor: pointer;
  }
  .header__burger span {
    display: block;
    width: 22px;
    height: 2px;
    background: #1d1e20;
    transition: transform 0.2s, opacity 0.2s;
  }
  /* Burger -> X */
  .header__burger--open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .header__burger--open span:nth-child(2) { opacity: 0; }
  .header__burger--open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  @media (min-width: 768px) {
    .header { padding: 12px 40px; }
    .header__logo img { height: 36px; }
    .header__nav { display: flex; }
    .header__burger { display: none; }
  }

  /* Vene ja inglise nav-sildid on pikemad: nav on alati nähtav nagu ET lehel,
     kitsamal ekraanil tihedam paigutus, et kõik ühele reale mahuks */
  .header--ru .header__nav a,
  .header--en .header__nav a { white-space: nowrap; }
  @media (min-width: 768px) and (max-width: 1279px) {
    .header--ru, .header--en { padding-left: 16px; padding-right: 16px; }
    .header--ru .header__nav, .header--en .header__nav { gap: 12px; }
    .header--ru .header__nav a, .header--en .header__nav a { font-size: 12.5px; }
  }

  /* Mobiilne täisekraani menüü */
  .mobile-menu {
    position: fixed;
    inset: 0;
    top: 49px; /* päise alt */
    background: #fff;
    z-index: 190;
    overflow-y: auto;
    padding: 24px;
  }
  .mobile-menu__nav {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 4px;
  }
  .mobile-menu__link {
    display: block;
    font-family: 'DM Sans', sans-serif;
    font-size: 20px;
    font-weight: 500;
    color: #1d1e20;
    text-decoration: none;
    padding: 12px 0;
    background: none;
    border: none;
    cursor: pointer;
    text-align: right;
  }
  .mobile-menu__link--active {
    text-decoration: underline;
    text-underline-offset: 5px;
  }
  .mobile-menu__arrow { font-size: 14px; margin-left: 4px; }
  .mobile-menu__sub {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 2px;
  }
  /* hidden-atribuut peab võitma display: flex'i — muidu on teenused alati lahti */
  .mobile-menu__sub[hidden] { display: none; }
  .mobile-menu__sublink {
    display: block;
    font-size: 18px;
    font-weight: 400;
    color: #1d1e20;
    text-decoration: none;
    padding: 10px 0;
  }
  :global(.cart-badge) {
    position: absolute;
    top: -6px;
    right: -8px;
    background: #1f6d85;
    color: #fff;
    font-size: 10px;
    font-weight: 700;
    min-width: 16px;
    height: 16px;
    border-radius: 999px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 4px;
  }
</style>
