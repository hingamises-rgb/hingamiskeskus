---
// Ühine päis: desktop nav + mobiilne täisekraani menüü (originaali järgi)
interface Props {
  active?: string; // avaleht | teenused | broneeri | epood | liikmeks | paketid | blogi | kkk
}
const { active = '' } = Astro.props;

const SERVICES = [
  { href: '/vabastav-hingamine', label: 'Vabastav hingamine' },
  { href: '/floating', label: 'Floating' },
  { href: '/neurovizr', label: 'Neurovizr' },
  { href: '/soojas-vees-hingamine', label: 'Soojas vees hingamine' },
  { href: '/aromatouch-kehahooldus', label: 'Aromatouch kehahooldus' },
  { href: '/ruumide-rent', label: 'Ruumide rent' },
  { href: '/terapeudid', label: 'Terapeudid' },
];

const NAV = [
  { href: '/', key: 'avaleht', label: 'Avaleht' },
  { href: '/teenused', key: 'teenused', label: 'Teenused' },
  { href: '/broneeri-aeg', key: 'broneeri', label: 'Broneeri aeg' },
  { href: '/e-pood', key: 'epood', label: 'E-pood' },
  { href: '/hakka-liikmeks', key: 'liikmeks', label: 'Hakka liikmeks' },
  { href: '/blogi', key: 'blogi', label: 'Blogi' },
  { href: '/kkk', key: 'kkk', label: 'KKK' },
];
---

<header class="header" id="site-header">
  <a href="/" class="header__logo">
    <img src="/images/logo.svg" alt="Hingamiskeskus" height="30" />
  </a>
  <nav class="header__nav">
    {NAV.map(item => (
      <a href={item.href} class={active === item.key ? 'active' : ''}>{item.label}</a>
    ))}
  </nav>
  <div class="header__right">
    <a href="/checkout" class="header__cart" aria-label="Ostukorv">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/>
      </svg>
    </a>
    <button class="header__burger" id="burger-btn" aria-label="Menüü" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<div class="mobile-menu" id="mobile-menu" hidden>
  <nav class="mobile-menu__nav">
    <a href="/" class={active === 'avaleht' ? 'mobile-menu__link mobile-menu__link--active' : 'mobile-menu__link'}>Avaleht</a>
    <button type="button" class="mobile-menu__link mobile-menu__toggle" id="services-toggle" aria-expanded="false">
      Teenused <span class="mobile-menu__arrow" id="services-arrow">▾</span>
    </button>
    <div class="mobile-menu__sub" id="services-sub" hidden>
      {SERVICES.map(s => (
        <a href={s.href} class="mobile-menu__sublink">{s.label}</a>
      ))}
    </div>
    <a href="/broneeri-aeg" class={active === 'broneeri' ? 'mobile-menu__link mobile-menu__link--active' : 'mobile-menu__link'}>Broneeri aeg</a>
    <a href="/e-pood" class={active === 'epood' ? 'mobile-menu__link mobile-menu__link--active' : 'mobile-menu__link'}>E-pood</a>
    <a href="/hakka-liikmeks" class={active === 'liikmeks' ? 'mobile-menu__link mobile-menu__link--active' : 'mobile-menu__link'}>Hakka liikmeks</a>
    <a href="/blogi" class={active === 'blogi' ? 'mobile-menu__link mobile-menu__link--active' : 'mobile-menu__link'}>Blogi</a>
    <a href="/kkk" class={active === 'kkk' ? 'mobile-menu__link mobile-menu__link--active' : 'mobile-menu__link'}>KKK</a>
  </nav>
</div>

<script is:inline>
(function() {
  const burger = document.getElementById('burger-btn');
  const menu = document.getElementById('mobile-menu');
  const servicesToggle = document.getElementById('services-toggle');
  const servicesSub = document.getElementById('services-sub');
  const servicesArrow = document.getElementById('services-arrow');

  burger.addEventListener('click', function() {
    const open = menu.hidden;
    menu.hidden = !open;
    burger.classList.toggle('header__burger--open', open);
    burger.setAttribute('aria-expanded', String(open));
    document.body.style.overflow = open ? 'hidden' : '';
  });

  servicesToggle.addEventListener('click', function() {
    const open = servicesSub.hidden;
    servicesSub.hidden = !open;
    servicesArrow.textContent = open ? '▴' : '▾';
    servicesToggle.setAttribute('aria-expanded', String(open));
  });

  // Ostukorvi loendur
  try {
    const cart = JSON.parse(localStorage.getItem('hk_cart') || '[]');
    const count = cart.reduce(function(s, i) { return s + i.qty; }, 0);
    if (count > 0) {
      const badge = document.createElement('span');
      badge.className = 'cart-badge';
      badge.textContent = count;
      document.querySelector('#site-header .header__cart').appendChild(badge);
    }
  } catch (e) {}
})();
</script>

<style>
  .header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 16px;
    background: #fff;
    position: sticky;
    top: 0;
    z-index: 200;
    border-bottom: 1px solid rgba(0,0,0,0.05);
  }
  .header__logo img { height: 28px; width: auto; }
  .header__nav { display: none; gap: 24px; }
  .header__nav a {
    font-size: 14px;
    color: #1d1e20;
    text-decoration: none;
    font-weight: 500;
  }
  .header__nav a.active {
    text-decoration: underline;
    text-underline-offset: 4px;
  }
  .header__right { display: flex; align-items: center; gap: 16px; }
  .header__cart { color: #1d1e20; position: relative; display: flex; }
  .header__burger {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    padding: 4px;
    width: 30px;
    height: 30px;
    background: none;
    border: none;
    cursor: pointer;
  }
  .header__burger span {
    display: block;
    width: 22px;
    height: 2px;
    background: #1d1e20;
    transition: transform 0.2s, opacity 0.2s;
  }
  /* Burger -> X */
  .header__burger--open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .header__burger--open span:nth-child(2) { opacity: 0; }
  .header__burger--open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  @media (min-width: 768px) {
    .header { padding: 12px 40px; }
    .header__logo img { height: 36px; }
    .header__nav { display: flex; }
    .header__burger { display: none; }
  }

  /* Mobiilne täisekraani menüü */
  .mobile-menu {
    position: fixed;
    inset: 0;
    top: 49px; /* päise alt */
    background: #fff;
    z-index: 190;
    overflow-y: auto;
    padding: 24px;
  }
  .mobile-menu__nav {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 4px;
  }
  .mobile-menu__link {
    display: block;
    font-family: 'DM Sans', sans-serif;
    font-size: 20px;
    font-weight: 500;
    color: #1d1e20;
    text-decoration: none;
    padding: 12px 0;
    background: none;
    border: none;
    cursor: pointer;
    text-align: right;
  }
  .mobile-menu__link--active {
    text-decoration: underline;
    text-underline-offset: 5px;
  }
  .mobile-menu__arrow { font-size: 14px; margin-left: 4px; }
  .mobile-menu__sub {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 2px;
  }
  .mobile-menu__sublink {
    display: block;
    font-size: 18px;
    font-weight: 400;
    color: #1d1e20;
    text-decoration: none;
    padding: 10px 0;
  }
  :global(.cart-badge) {
    position: absolute;
    top: -6px;
    right: -8px;
    background: #1f6d85;
    color: #fff;
    font-size: 10px;
    font-weight: 700;
    min-width: 16px;
    height: 16px;
    border-radius: 999px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 4px;
  }
</style>
