---
import Popup from '../components/Popup.astro';

interface Props {
  title: string;
  description?: string;
  keywords?: string;
  image?: string;
  type?: string;
  noindex?: boolean;
  lang?: 'et' | 'ru' | 'en';
  /** Sama lehe teiste keelte URL-id hreflang jaoks, nt { et: '/teenused', ru: '/ru/uslugi', en: '/en/services' } */
  alternates?: Partial<Record<'et' | 'ru' | 'en', string>>;
  /** Lehespetsiifiline JSON-LD schema (nt FAQPage, Product, BlogPosting) */
  schema?: object | object[];
}
const {
  title,
  description = 'Hingamiskeskus - vabastav hingamine ja floating Tallinnas. Sõle 14c.',
  keywords = '',
  image = '/images/hero-bg.jpg',
  type = 'website',
  noindex = false,
  lang = 'et',
  alternates,
  schema,
} = Astro.props;

const SITE = 'https://www.hingamiskeskus.ee';
const canonicalUrl = SITE + Astro.url.pathname;
const ogImage = image.startsWith('http') ? image : SITE + image;
const ogLocale = lang === 'ru' ? 'ru_RU' : lang === 'en' ? 'en_GB' : 'et_EE';

// Saidiülene LocalBusiness JSON-LD (AI-otsingud ja Google loevad faktid otse siit).
// NB: andmed peavad klappima jaluse ja Google Business Profile'iga (NAP-konsistentsus).
const LOCAL_BUSINESS = {
  '@context': 'https://schema.org',
  '@type': 'HealthAndBeautyBusiness',
  '@id': `${SITE}/#organization`,
  name: 'Hingamiskeskus',
  alternateName: lang === 'ru' ? 'Центр дыхания' : 'Hingamiskeskus OÜ',
  description:
    lang === 'ru'
      ? 'Флоатинг и освобождающее дыхание в Таллине: глубокое расслабление, снятие стресса и восстановление.'
      : lang === 'en'
      ? 'Floating and breathwork in Tallinn: deep relaxation, stress relief and recovery.'
      : 'Floating ja vabastav hingamine Tallinnas: süvalõõgastus, stressi leevendus ja taastumine.',
  url: SITE,
  logo: `${SITE}/images/logo.svg`,
  image: `${SITE}/images/hoone.jpg`,
  telephone: '+372 56695898',
  email: 'info@hingamiskeskus.ee',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Sõle 14c',
    addressLocality: 'Tallinn',
    addressCountry: 'EE',
  },
  openingHoursSpecification: [
    { '@type': 'OpeningHoursSpecification', dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'], opens: '08:30', closes: '20:00' },
    { '@type': 'OpeningHoursSpecification', dayOfWeek: ['Saturday', 'Sunday'], opens: '11:00', closes: '18:00' },
  ],
  priceRange: '€€',
  sameAs: [
    'https://www.facebook.com/Hingamiskeskus',
    'https://www.instagram.com/hingamiskeskus/',
  ],
};

const pageSchemas = schema ? (Array.isArray(schema) ? schema : [schema]) : [];
---
<!doctype html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href="/images/logo.svg" />
  <title>{title}</title>
  <meta name="description" content={description} />
  {keywords && <meta name="keywords" content={keywords} />}
  <meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow'} />
  <link rel="canonical" href={canonicalUrl} />
  {alternates?.et && <link rel="alternate" hreflang="et" href={SITE + alternates.et} />}
  {alternates?.ru && <link rel="alternate" hreflang="ru" href={SITE + alternates.ru} />}
  {alternates?.en && <link rel="alternate" hreflang="en" href={SITE + alternates.en} />}
  {alternates?.et && <link rel="alternate" hreflang="x-default" href={SITE + alternates.et} />}

  <!-- Open Graph (Facebook, WhatsApp jt jagamised) -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:type" content={type} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:site_name" content="Hingamiskeskus" />
  <meta property="og:locale" content={ogLocale} />
  <meta name="twitter:card" content="summary_large_image" />

  <!-- Struktureeritud andmed (JSON-LD): ettevõtte faktid + lehespetsiifiline schema -->
  <script type="application/ld+json" set:html={JSON.stringify(LOCAL_BUSINESS)} />
  {pageSchemas.map((s) => (
    <script type="application/ld+json" set:html={JSON.stringify({ '@context': 'https://schema.org', ...s })} />
  ))}

  <!-- Meta Pixel + GA4 laetakse AINULT pärast küpsisenõusolekut (GDPR).
       Valik salvestub localStorage hk_consent: 'all' | 'necessary'. -->
  <script is:inline>
    window.hkLoadTrackers = function () {
      if (window.hkTrackersLoaded) return;
      window.hkTrackersLoaded = true;
      !function(f,b,e,v,n,t,s)
      {if(f.fbq)return;n=f.fbq=function(){n.callMethod?
      n.callMethod.apply(n,arguments):n.queue.push(arguments)};
      if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
      n.queue=[];t=b.createElement(e);t.async=!0;
      t.src=v;s=b.getElementsByTagName(e)[0];
      s.parentNode.insertBefore(t,s)}(window, document,'script',
      'https://connect.facebook.net/en_US/fbevents.js');
      fbq('init', '395736756494375');
      fbq('track', 'PageView');
      var g = document.createElement('script');
      g.async = true;
      g.src = 'https://www.googletagmanager.com/gtag/js?id=G-S5EP0KSWTQ';
      document.head.appendChild(g);
      window.dataLayer = window.dataLayer || [];
      window.gtag = function(){ dataLayer.push(arguments); };
      gtag('js', new Date());
      gtag('config', 'G-S5EP0KSWTQ');
    };
    if (localStorage.getItem('hk_consent') === 'all') window.hkLoadTrackers();
  </script>
</head>
<body>
  <slot />
  <Popup />

  <!-- Küpsisenõusoleku riba (kuvatakse ainult siis, kui valikut pole tehtud) -->
  <div id="hk-consent" hidden>
    <p>
      {lang === 'ru'
        ? 'Мы используем файлы cookie для работы сайта и для статистики посещений.'
        : lang === 'en'
        ? 'We use cookies to run this site and to measure visits.'
        : 'Kasutame küpsiseid lehe toimimiseks ja külastusstatistika mõõtmiseks.'}
      <a href="/privaatsuspoliitika">{lang === 'ru' ? 'Подробнее' : lang === 'en' ? 'Learn more' : 'Loe lähemalt'}</a>
    </p>
    <div class="hk-consent__btns">
      <button id="hk-consent-all">{lang === 'ru' ? 'Согласен' : lang === 'en' ? 'Accept' : 'Nõustun'}</button>
      <button id="hk-consent-nec">{lang === 'ru' ? 'Только необходимые' : lang === 'en' ? 'Only necessary' : 'Ainult vajalikud'}</button>
    </div>
  </div>
  <script is:inline>
    (function () {
      var box = document.getElementById('hk-consent');
      if (!box || localStorage.getItem('hk_consent')) return;
      box.hidden = false;
      function choose(val) {
        localStorage.setItem('hk_consent', val);
        box.hidden = true;
        if (val === 'all') window.hkLoadTrackers();
      }
      document.getElementById('hk-consent-all').addEventListener('click', function () { choose('all'); });
      document.getElementById('hk-consent-nec').addEventListener('click', function () { choose('necessary'); });
    })();
  </script>
</body>
</html>

<style is:global>
  @import url('https://fonts.googleapis.com/css2?family=DM+Sans:ital,wght@0,400;0,500;0,700;1,400;1,500&family=Libre+Caslon+Display&display=swap');

  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html { scroll-behavior: smooth; }

  /* Küpsisenõusoleku riba */
  #hk-consent {
    position: fixed;
    left: 16px;
    right: 16px;
    bottom: 16px;
    z-index: 500;
    background: #1d1e20;
    color: #fff;
    border-radius: 12px;
    padding: 16px 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    flex-wrap: wrap;
    box-shadow: 0 6px 24px rgba(0,0,0,0.25);
  }
  #hk-consent[hidden] { display: none; }
  #hk-consent p { margin: 0; font-size: 14px; }
  #hk-consent a { color: #9fd3e4; text-decoration: underline; }
  .hk-consent__btns { display: flex; gap: 10px; flex-wrap: wrap; }
  #hk-consent button {
    font: inherit;
    font-size: 14px;
    padding: 10px 18px;
    border-radius: 8px;
    cursor: pointer;
    border: 1px solid #fff;
  }
  #hk-consent-all { background: #1f6d85; border-color: #1f6d85; color: #fff; font-weight: 700; }
  #hk-consent-nec { background: none; color: #fff; }

  body {
    font-family: 'DM Sans', sans-serif;
    color: #1d1e20;
    background: #fff;
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }

  p, li, span, td, th, dd, dt, label {
    font-size: 18px;
  }

  h1, h2, h3 {
    text-align: center;
  }

  .footer__main h3,
  .footer__contact h3,
  .footer__hours h3 {
    text-align: left;
  }

  a { color: inherit; text-decoration: none; }
  img { max-width: 100%; height: auto; display: block; }
  button { font-family: inherit; cursor: pointer; border: none; background: none; }
  ul, ol { list-style: none; }
</style>
