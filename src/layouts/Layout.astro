---
interface Props {
  title: string;
}
const { title } = Astro.props;
---
<!doctype html>
<html lang="et">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href="/images/logo.svg" />
  <title>{title}</title>
  <meta name="description" content="Hingamiskeskus - vabastav hingamine ja floating Tallinnas. Söle 14c." />
</head>
<body>
  <slot />
</body>
</html>

<style is:global>
  @import url('https://fonts.googleapis.com/css2?family=DM+Sans:ital,wght@0,400;0,500;0,700;1,400;1,500&family=Libre+Caslon+Display&display=swap');

  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'DM Sans', sans-serif;
    color: #1d1e20;
    background: #fff;
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }

  p, li, span, td, th, dd, dt, label {
    font-size: 18px;
  }

  h1, h2, h3 {
    text-align: center;
  }

  .footer__main h3,
  .footer__contact h3,
  .footer__hours h3 {
    text-align: left;
  }

  a { color: inherit; text-decoration: none; }
  img { max-width: 100%; height: auto; display: block; }
  button { font-family: inherit; cursor: pointer; border: none; background: none; }
  ul, ol { list-style: none; }
</style>
