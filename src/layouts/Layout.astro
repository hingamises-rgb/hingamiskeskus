---
import Popup from '../components/Popup.astro';

interface Props {
  title: string;
  description?: string;
  keywords?: string;
  image?: string;
  type?: string;
  noindex?: boolean;
  lang?: 'et' | 'ru';
  /** Sama lehe teiste keelte URL-id hreflang jaoks, nt { et: '/teenused', ru: '/ru/uslugi' } */
  alternates?: Partial<Record<'et' | 'ru', string>>;
  /** Lehespetsiifiline JSON-LD schema (nt FAQPage, Product, BlogPosting) */
  schema?: object | object[];
}
const {
  title,
  description = 'Hingamiskeskus - vabastav hingamine ja floating Tallinnas. Sõle 14c.',
  keywords = '',
  image = '/images/hero-bg.jpg',
  type = 'website',
  noindex = false,
  lang = 'et',
  alternates,
  schema,
} = Astro.props;

const SITE = 'https://www.hingamiskeskus.ee';
const canonicalUrl = SITE + Astro.url.pathname;
const ogImage = image.startsWith('http') ? image : SITE + image;
const ogLocale = lang === 'ru' ? 'ru_RU' : 'et_EE';

// Saidiülene LocalBusiness JSON-LD (AI-otsingud ja Google loevad faktid otse siit).
// NB: andmed peavad klappima jaluse ja Google Business Profile'iga (NAP-konsistentsus).
const LOCAL_BUSINESS = {
  '@context': 'https://schema.org',
  '@type': 'HealthAndBeautyBusiness',
  '@id': `${SITE}/#organization`,
  name: 'Hingamiskeskus',
  alternateName: lang === 'ru' ? 'Центр дыхания' : 'Hingamiskeskus OÜ',
  description:
    lang === 'ru'
      ? 'Флоатинг и освобождающее дыхание в Таллине: глубокое расслабление, снятие стресса и восстановление.'
      : 'Floating ja vabastav hingamine Tallinnas: süvalõõgastus, stressi leevendus ja taastumine.',
  url: SITE,
  logo: `${SITE}/images/logo.svg`,
  image: `${SITE}/images/hoone.jpg`,
  telephone: '+372 56695898',
  email: 'info@hingamiskeskus.ee',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Sõle 14c',
    addressLocality: 'Tallinn',
    addressCountry: 'EE',
  },
  openingHoursSpecification: [
    { '@type': 'OpeningHoursSpecification', dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'], opens: '08:30', closes: '20:00' },
    { '@type': 'OpeningHoursSpecification', dayOfWeek: ['Saturday', 'Sunday'], opens: '11:00', closes: '18:00' },
  ],
  priceRange: '€€',
  sameAs: [
    'https://www.facebook.com/Hingamiskeskus',
    'https://www.instagram.com/hingamiskeskus/',
  ],
};

const pageSchemas = schema ? (Array.isArray(schema) ? schema : [schema]) : [];
---
<!doctype html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href="/images/logo.svg" />
  <title>{title}</title>
  <meta name="description" content={description} />
  {keywords && <meta name="keywords" content={keywords} />}
  <meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow'} />
  <link rel="canonical" href={canonicalUrl} />
  {alternates?.et && <link rel="alternate" hreflang="et" href={SITE + alternates.et} />}
  {alternates?.ru && <link rel="alternate" hreflang="ru" href={SITE + alternates.ru} />}
  {alternates?.et && <link rel="alternate" hreflang="x-default" href={SITE + alternates.et} />}

  <!-- Open Graph (Facebook, WhatsApp jt jagamised) -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:type" content={type} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:site_name" content="Hingamiskeskus" />
  <meta property="og:locale" content={ogLocale} />
  <meta name="twitter:card" content="summary_large_image" />

  <!-- Struktureeritud andmed (JSON-LD): ettevõtte faktid + lehespetsiifiline schema -->
  <script type="application/ld+json" set:html={JSON.stringify(LOCAL_BUSINESS)} />
  {pageSchemas.map((s) => (
    <script type="application/ld+json" set:html={JSON.stringify({ '@context': 'https://schema.org', ...s })} />
  ))}

  <!-- Meta Pixel -->
  <script is:inline>
    !function(f,b,e,v,n,t,s)
    {if(f.fbq)return;n=f.fbq=function(){n.callMethod?
    n.callMethod.apply(n,arguments):n.queue.push(arguments)};
    if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
    n.queue=[];t=b.createElement(e);t.async=!0;
    t.src=v;s=b.getElementsByTagName(e)[0];
    s.parentNode.insertBefore(t,s)}(window, document,'script',
    'https://connect.facebook.net/en_US/fbevents.js');
    fbq('init', '395736756494375');
    fbq('track', 'PageView');
  </script>
  <noscript>
    <img height="1" width="1" style="display:none"
      src="https://www.facebook.com/tr?id=395736756494375&ev=PageView&noscript=1" />
  </noscript>

  <!-- Google Analytics 4 (gtag) -->
  <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-S5EP0KSWTQ"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-S5EP0KSWTQ');
  </script>
</head>
<body>
  <slot />
  <Popup />
</body>
</html>

<style is:global>
  @import url('https://fonts.googleapis.com/css2?family=DM+Sans:ital,wght@0,400;0,500;0,700;1,400;1,500&family=Libre+Caslon+Display&display=swap');

  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'DM Sans', sans-serif;
    color: #1d1e20;
    background: #fff;
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }

  p, li, span, td, th, dd, dt, label {
    font-size: 18px;
  }

  h1, h2, h3 {
    text-align: center;
  }

  .footer__main h3,
  .footer__contact h3,
  .footer__hours h3 {
    text-align: left;
  }

  a { color: inherit; text-decoration: none; }
  img { max-width: 100%; height: auto; display: block; }
  button { font-family: inherit; cursor: pointer; border: none; background: none; }
  ul, ol { list-style: none; }
</style>
