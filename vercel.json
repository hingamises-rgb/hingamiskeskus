{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/booking/reminders",
      "schedule": "0 6 * * *"
    }
  ],
  "redirects": [
    {
      "source": "/sitemap.xml",
      "destination": "/sitemap-index.xml",
      "permanent": true
    },
    {
      "source": "/privaatsuspoliitika-and-muugitingimused",
      "destination": "/privaatsuspoliitika",
      "permanent": true
    },
    {
      "source": "/paketid",
      "destination": "/e-pood",
      "permanent": true
    },
    {
      "source": "/reiki",
      "destination": "/teenused",
      "permanent": true
    },
    {
      "source": "/uritused",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/ru/pakety",
      "destination": "/ru/onlajn-shop",
      "permanent": true
    }
  ]
}